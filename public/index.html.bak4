function ph(){HP.push(JSON.stringify(S));if(HP.length>50)HP.shift();HF=[];uu();}
function uu(){var u=document.getElementById('ub'),r=document.getElementById('rb');if(u)u.disabled=!HP.length;if(r)r.disabled=!HF.length;}
function toast(m){var t=document.getElementById('toast');t.textContent=m;t.className='toast show';clearTimeout(t._t);t._t=setTimeout(function(){t.className='toast';},2200);}
function cl(v){return{min:'نظيف',dark:'داكن',grad:'متدرج',viv:'حيوي',nat:'طبيعي',eleg:'أنيق',bold:'جريء'}[v]||v;}
function rSide(){var sb=document.getElementById('customize-panels'),h='';SB.forEach(function(s){h+='<div class="ss"><div class="sh open" onclick="ts(this)"><span>'+s.ic+' '+s.tt+'</span><span class="sa">▼</span></div><div class="sb open">';if(s.tp==='qa'){h+='<div class="sc"><div class="sl">⚡ ستايلات جاهزة</div><div class="qag">';QA.forEach(function(q,i){h+='<button class="qab" onclick="aq('+i+')" style="background:linear-gradient(135deg,'+q.bg+','+(q.bg2||q.bg)+');color:'+q.fc+'">'+q.nm+'</button>';});h+='</div><button class="abtn" style="width:100%;margin-top:4px;text-align:center" onclick="rd()">🔄 إعادة تعيين</button></div>';}
else if(s.tp==='vis'){h+='<div class="sc"><div class="sl">الأقسام</div>';SC.forEach(function(k){h+='<div class="tg '+(S.sectionVisibility[k]!==false?'on':'')+'" onclick="tsSec(\''+k+'\')"><div class="td">✓</div><span class="tl">'+SE[k]+' '+SL[k]+'</span></div>';});h+='</div><div class="sc"><div class="sl">العناصر</div>';[{k:'showBadge',l:'🏷️ Badges'},{k:'showUnitBadge',l:'📘 Unit'},{k:'showMeaning',l:'🇸🇦 المعنى'},{k:'showPage',l:'📄 الصفحة'}].forEach(function(x){h+='<div class="tg '+(S[x.k]?'on':'')+'" onclick="tsBool(\''+x.k+'\')"><div class="td">✓</div><span class="tl">'+x.l+'</span></div>';});h+='</div>';}
else if(s.tp==='srt'){h+='<div class="sc"><div class="sl">اربط بالترتيب</div>';S.sectionOrder.forEach(function(k,i){h+='<div class="srt" draggable="true" ondragstart="dS(event,'+i+')" ondragover="event.preventDefault()" ondrop="dD(event,'+i+')"><span style="color:var(--tx3)">⋮⋮</span><span class="srn">'+(i+1)+'</span><span>'+SE[k]+' '+SL[k]+'</span></div>';});h+='</div>';}
else if(s.tp==='tpl'){var sv=JSON.parse(localStorage.getItem('anki_tpls')||'{}'),ns=Object.keys(sv);h+='<div class="sc"><div class="sl">القوالب</div>';if(ns.length){ns.forEach(function(n){h+='<div style="display:flex;gap:3px;align-items:center;padding:3px 6px;background:var(--s3);border-radius:3px;font-size:.62em;margin-bottom:2px"><span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">'+n+'</span><button class="abtn" style="padding:1px 4px;font-size:.52em" onclick="lT(\''+n.replace(/'/g,"\\'")+'\')">📂</button><button class="abtn rd" style="padding:1px 4px;font-size:.52em" onclick="dT(\''+n.replace(/'/g,"\\'")+'\')">🗑️</button></div>';});}else h+='<div style="font-size:.62em;color:var(--tx3);text-align:center;padding:4px">لا توجد</div>';h+='<button class="abtn gn" style="width:100%;margin-top:4px;text-align:center" onclick="oS()">💾 حفظ الحالي</button></div>';}
else if(s.tp==='pal'){h+='<div class="sc"><div class="sl">🎨 أدخل لون</div><div class="sr"><input type="color" class="clr" id="palIn" value="#6366f1" oninput="gPal(this.value)"><button class="abtn" onclick="gPal(document.getElementById(\'palIn\').value)">generate</button></div><div id="palOut" style="margin-top:4px"></div></div>';}
else if(s.fd){s.fd.forEach(function(f){if(f.t==='fx'){h+='<div class="sc"><div class="sl">'+f.lb+'</div><div class="fxg">';FX.forEach(function(x){h+='<button class="fxb '+(S[f.id]===x.i?'on':'')+'" onclick="setFx(\''+x.i+'\')">'+x.e+' '+x.n+'</button>';});h+='</div></div>';}else if(f.t==='c'){h+='<div class="sc"><div class="sl">'+f.lb+'</div><div class="sr"><input type="color" class="clr" value="'+(S[f.id]||'#ffffff')+'" oninput="setC(\''+f.id+'\',this.value)"><input type="text" class="hx" value="'+(S[f.id]||'')+'" onchange="setC(\''+f.id+'\',this.value)"></div></div>';}else if(f.t==='r'){var v=S[f.id]!==undefined?S[f.id]:f.d;h+='<div class="sc"><div class="sl">'+f.lb+'</div><div class="sr"><div class="rg"><input type="range" min="'+f.mn+'" max="'+f.mx+'" step="'+f.st+'" value="'+v+'" oninput="setR(\''+f.id+'\',this.value,\''+f.u+'\')"><span class="rv" id="rv_'+f.id+'">'+v+f.u+'</span></div></div></div>';}else if(f.t==='s'){h+='<div class="sc"><div class="sl">'+f.lb+'</div><select class="sl2" onchange="setS(\''+f.id+'\',this.value)">';f.o.forEach(function(o){h+='<option value="'+o+'" '+(S[f.id]===o?'selected':'')+'>'+o+'</option>';});h+='</select></div>';if(f.fp){h+='<div class="fp"><div class="s" style="font-family:'+(S[f.id]||f.d)+'">The quick brown fox</div><div class="n">'+(S[f.id]||f.d).split(",")[0].replace(/'/g,'')+'</div></div>';}}else if(f.t==='x')h+='<div class="sc"><div class="sl">'+f.lb+'</div><input type="text" class="tx" value="'+(S[f.id]||'')+'" placeholder="0 2px 8px rgba(0,0,0,.3)" onchange="setT(\''+f.id+'\',this.value)"></div>';else if(f.t==='txt')h+='<div class="sc"><div class="sl">'+f.lb+'</div><input type="text" class="tx" value="'+(S[f.id]||f.d||'')+'" onchange="setT(\''+f.id+'\',this.value)"></div>';});}h+='</div></div>';});sb.innerHTML=h;}
function ts(el){el.classList.toggle('open');el.nextElementSibling.classList.toggle('open');}
function rGal(){var g=document.getElementById('ggrid'),q=(document.getElementById('gsrch').value||'').toLowerCase();var f=T.filter(function(t){if(S.cat!=='all'&&t.c!==S.cat)return false;if(q&&t.n.indexOf(q)===-1&&t.en.toLowerCase().indexOf(q)===-1)return false;return true;});document.getElementById('gct').textContent=f.length+'/'+T.length;if(!f.length){g.innerHTML='<div class="emp"><span>🔍</span><div>لا توجد نتائج</div></div>';return;}g.innerHTML=f.map(function(t,vi){var ri=T.indexOf(t),sel=ri===S.sel?'sel':'',bg=t.bg2?'linear-gradient(135deg,'+t.bg+','+t.bg2+')':t.bg,fv=FAV.indexOf(ri)!==-1;return '<div class="tc '+sel+'" style="animation-delay:'+Math.min(vi*30,400)+'ms" onclick="sT('+ri+')"><button class="fv '+(fv?'on':'')+'" onclick="event.stopPropagation();tFv('+ri+')">'+(fv?'❤️':'🤍')+'</button><div class="tp" style="background:'+bg+'"><div style="font-family:Inter;font-size:.9em;font-weight:900;color:'+t.fc+';direction:ltr;margin-bottom:4px">'+SA.f+'</div><div style="background:'+t.mb+';border:1px solid '+t.mbd+';border-radius:6px;padding:2px 8px;color:'+t.mc+';font-size:.65em;font-family:\'Noto Sans Arabic\'">'+SA.a+'</div><div style="margin-top:3px"><span style="background:'+t.bnbg+';color:'+t.bnc+';padding:1px 4px;border-radius:4px;font-size:.42em;font-weight:700">N.</span> <span style="background:'+t.ubg+';color:'+t.uc+';padding:1px 4px;border-radius:4px;font-size:.42em;font-weight:700;border:1px solid '+t.ubd+'">Unit 1</span></div></div><div class="ti"><div><span class="tn">'+t.n+'</span><span class="te">'+t.en+'</span></div><span class="tt">'+cl(t.c)+'</span></div></div>';}).join('');}
function gFil(){var m={all:'الكل',min:'نظيف',dark:'داكن',grad:'متدرج',viv:'حيوي',nat:'طبيعي',eleg:'أنيق',bold:'جريء'};document.getElementById('gfil').innerHTML=Object.entries(m).map(function(kv){return '<button class="gb '+(kv[0]===S.cat?'on':'')+'" onclick="setCt(\''+kv[0]+'\')">'+kv[1]+'</button>';}).join('');}
function setCt(c){S.cat=c;gFil();rGal();}
function sT(i){ph();S.sel=i;var t=T[i];S.cardBg=t.bg;S.cardBg2=t.bg2||'';S.frenchColor=t.fc;S.meaningBg=t.mb;S.meaningBorder=t.mbd;S.meaningColor=t.mc;S.textColor=t.tc;S.badgeNomBg=t.bnbg;S.badgeNomColor=t.bnc;S.badgeAdjBg=t.babg;S.badgeAdjColor=t.bac;S.badgeVerbBg=t.bvbg;S.badgeVerbColor=t.bvc;S.unitBg=t.ubg;S.unitColor=t.uc;S.unitBorder=t.ubd;S.secBg=t.sb;S.secBorder=t.sbd;S.secTextColor=t.sc;S.labelColor=t.lc;if(t.fx)S.effect=t.fx;rGal();rSide();uP();toast('✅ '+t.n);}
function tFv(i){var x=FAV.indexOf(i);if(x===-1){FAV.push(i);toast('❤️');}else{FAV.splice(x,1);toast('💔');}localStorage.setItem('anki_favs',JSON.stringify(FAV));rGal();}
function setC(id,v){ph();S[id]=v;uP();rSide();}
function setR(id,v,u){S[id]=parseFloat(v);var rv=document.getElementById('rv_'+id);if(rv)rv.textContent=v+u;uP();}
function setS(id,v){ph();S[id]=v;uP();rSide();}
function setT(id,v){ph();S[id]=v;uP();}
function setFx(id){ph();S.effect=id;rSide();uP();}
function tsSec(k){ph();S.sectionVisibility[k]=S.sectionVisibility[k]===false?true:false;rSide();uP();}
function tsBool(k){ph();S[k]=!S[k];rSide();uP();}
var dI=null;
function dS(e,i){dI=i;e.target.classList.add('dragging');e.dataTransfer.effectAllowed='move';}
function dD(e,i){e.preventDefault();if(dI===null||dI===i)return;ph();var it=S.sectionOrder.splice(dI,1)[0];S.sectionOrder.splice(i,0,it);dI=null;rSide();uP();}
function aq(i){ph();var q=QA[i];Object.keys(q).forEach(function(k){if(k!=='nm'&&k in S)S[k]=q[k];});rSide();uP();toast('⚡ '+q.nm);}
function rd(){ph();SB.forEach(function(s){if(s.fd)s.fd.forEach(function(f){if(f.id)S[f.id]=f.d;});});S.sectionOrder=SC.slice();SC.forEach(function(k){S.sectionVisibility[k]=true;});S.showBadge=true;S.showUnitBadge=true;S.showMeaning=true;S.showPage=true;S.effect='none';S.sp='unived';rSide();uP();toast('🔄 إعادة تعيين');}
function gPal(hex){var r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16);var l='rgb('+Math.min(255,r+100)+','+Math.min(255,g+100)+','+Math.min(255,b+100)+')',d='rgb('+Math.max(0,r-80)+','+Math.max(0,g-80)+','+Math.max(0,b-80)+')',c='rgb('+(255-r)+','+(255-g)+','+(255-b)+')';document.getElementById('palOut').innerHTML='<div style="display:flex;gap:3px;flex-wrap:wrap"><div style="width:100%;padding:3px 6px;background:'+hex+';color:#fff;border-radius:3px;font-size:.58em;text-align:center;font-weight:600">أساسي: '+hex+'</div><div style="flex:1;min-width:45px;padding:3px;background:'+l+';color:#333;border-radius:3px;font-size:.52em;text-align:center">فاتح</div><div style="flex:1;min-width:45px;padding:3px;background:'+d+';color:#fff;border-radius:3px;font-size:.52em;text-align:center">غامق</div><div style="flex:1;min-width:45px;padding:3px;background:'+c+';color:#fff;border-radius:3px;font-size:.52em;text-align:center">مكمل</div></div>';}
function mkCard(){var bg=S.cardBg2?'linear-gradient('+(S.bgGradientDir||'135deg')+','+S.cardBg+','+S.cardBg2+')':S.cardBg;var c='background:'+bg+';border-radius:'+(S.borderRadius||16)+'px;padding:'+(S.cardPadding||28)+'px 20px;min-height:'+(S.cardMinHeight||300)+'px;display:flex;flex-direction:'+(S.cardDirection||'column')+';align-items:'+(S.cardAlign||'center')+';justify-content:center;color:'+(S.textColor||'#333')+';gap:'+(S.cardGap||10)+'px;font-family:'+(S.fontArabic||"'Noto Sans Arabic'")+';width:100%;box-sizing:border-box;';if(S.cardBorderWidth)c+='border:'+S.cardBorderWidth+'px solid '+(S.cardBorderColor||'#e2e8f0')+';';if(S.cardShadow&&S.cardShadow!=='none')c+='box-shadow:'+S.cardShadow+';';var h='<div style="'+c+'">';h+='<div style="font-family:'+(S.fontFrench||"'Inter'")+';font-size:'+(S.frenchFontSize||2.4)+'em;font-weight:'+(S.frenchFontWeight||900)+';direction:ltr;color:'+(S.frenchColor||'#1e293b')+';'+(S.frenchTextShadow?'text-shadow:'+S.frenchTextShadow+';':'')+'">'+SA.f+'</div>';if(S.showBadge)h+='<div style="margin:4px 0"><span style="background:'+(S.badgeNomBg||'#dbeafe')+';color:'+(S.badgeNomColor||'#1e40af')+';padding:3px 12px;border-radius:16px;font-size:.68em;font-weight:700;display:inline-block;margin:2px;'+(S.badgeShadow?'box-shadow:'+S.badgeShadow+';':'')+'">'+SA.tp+'</span></div>';if(S.showUnitBadge)h+='<div style="margin:4px 0"><span style="background:'+(S.unitBg||'#f0fdf4')+';color:'+(S.unitColor||'#166534')+';border:1px solid '+(S.unitBorder||'#bbf7d0')+';padding:2px 10px;border-radius:16px;font-size:.64em;font-weight:700;display:inline-block;margin:2px">Unit '+SA.u+'</span></div>';h+='<hr style="border:none;border-top:1px '+(S.separatorStyle||'dashed')+' '+(S.separatorColor||'#e2e8f0')+';margin:4px 20px;width:100%">';if(S.showMeaning)h+='<div style="background:'+(S.meaningBg||'#eff6ff')+';border:'+(S.meaningBorderWidth||2)+'px solid '+(S.meaningBorder||'#bfdbfe')+';border-radius:'+(S.meaningBorderRadius||16)+'px;padding:10px 18px;color:'+(S.meaningColor||'#1e40af')+';font-size:'+(S.meaningFontSize||1.5)+'em;font-weight:'+(S.meaningFontWeight||800)+';max-width:90%">'+SA.a+'</div>';var sd={pluriel:{l:'Pluriel',v:SA.p},masculin:{l:'Masc.',v:'Un abonnement / Des abonnements'},feminin:{l:'Fem.',v:'Une abonnée / Des abonnées'},preposition:{l:'Prep.',v:'abonner à'},auxiliaire:{l:'Aux.',v:'avoir'},participe:{l:'Part.',v:'abonné'},synonyme:{l:'Syn.',v:'adhésion'},contraire:{l:'Contr.',v:'désabonnement'}};S.sectionOrder.forEach(function(k){if(S.sectionVisibility[k]===false)return;var s=sd[k];if(!s)return;h+='<div style="background:'+(S.secBg||'#f8f9fa')+';border:1px solid '+(S.secBorder||'#e2e8f0')+';border-radius:10px;padding:8px 14px;margin:3px 0;width:100%;max-width:460px;text-align:center"><div style="font-size:.55em;color:'+(S.labelColor||'#999')+';text-transform:uppercase;letter-spacing:1.5px;margin-bottom:2px">'+s.l+'</div><div style="font-size:.82em;font-weight:700;direction:ltr;color:'+(S.secTextColor||'#333')+'">'+s.v+'</div></div>';});if(S.showPage)h+='<div style="font-size:.55em;color:'+(S.labelColor||'#999')+';margin-top:3px">Page 12</div>';h+='</div>';return h;}
function uP(){var f=document.getElementById('pvF'),b=document.getElementById('pvB');if(f)f.innerHTML=mkCard();if(b)b.innerHTML=mkCard();}
function flip(){document.getElementById('fip').classList.toggle('flipped');}
function go(id){document.querySelectorAll('.tc2').forEach(function(t){t.classList.remove('on');});document.querySelectorAll('.tab').forEach(function(t){t.classList.remove('on');});document.getElementById('t-'+id).classList.add('on');document.querySelector('[data-t="'+id+'"]').classList.add('on');if(id==='pv')uP();if(id==='dl')rSts();document.querySelector('.main').scrollTo({top:0,behavior:'smooth'});}
function scr2(s,el){document.querySelectorAll('.scr button').forEach(function(b){b.classList.remove('on');});el.classList.add('on');var bw=s==='mob'?'375px':s==='tab'?'768px':'100%';document.querySelectorAll('.box').forEach(function(b){b.style.maxWidth=bw;});}
function setSp(v,b){S.sp=v;document.querySelectorAll('.spb').forEach(function(x){x.classList.remove('on');});b.classList.add('on');}
function togSide(){var s=document.getElementById('side');s.classList.toggle('open');s.classList.toggle('shut');}
function rSts(){document.getElementById('dsts').innerHTML='<div class="sti"><div class="stv">3,487</div><div class="stl">كلمة</div></div><div class="sti"><div class="stv">735</div><div class="stl">مهمة</div></div><div class="sti"><div class="stv">6</div><div class="stl">وحدات</div></div><div class="sti"><div class="stv">~300KB</div><div class="stl">حجم متوقع</div></div><div class="sti"><div class="stv">'+T.length+'</div><div class="stl">قالب</div></div>';}
function undo(){if(!HP.length)return;HF.push(JSON.stringify(S));Object.assign(S,JSON.parse(HP.pop()));rGal();rSide();uP();uu();}
function redo(){if(!HF.length)return;HP.push(JSON.stringify(S));Object.assign(S,JSON.parse(HF.pop()));rGal();rSide();uP();uu();}
function oS(){document.getElementById('tname').value='';document.getElementById('mSave').classList.add('show');setTimeout(function(){document.getElementById('tname').focus();},100);}
function cfs(){var n=document.getElementById('tname').value.trim();if(!n){toast('❌ أدخل اسمًا');return;}var sv=JSON.parse(localStorage.getItem('anki_tpls')||'{}');sv[n]={c:bC(),s:S.sel};localStorage.setItem('anki_tpls',JSON.stringify(sv));cm('mSave');rSide();toast('💾 '+n);}
function lT(n){var sv=JSON.parse(localStorage.getItem('anki_tpls')||'{}');if(!sv[n])return;ph();var c=sv[n].c;Object.keys(c).forEach(function(k){if(k in S)S[k]=c[k];});if(c.sectionOrder)S.sectionOrder=c.sectionOrder.split(',');if(c.sectionVisibility)S.sectionVisibility=c.sectionVisibility;if(c.effect)S.effect=c.effect;if(c.splitDirection)S.sp=c.splitDirection;if(sv[n].s!==undefined)S.sel=sv[n].s;rGal();rSide();uP();toast('📂 '+n);}
function dT(n){if(!confirm('حذف "'+n+'"؟'))return;var sv=JSON.parse(localStorage.getItem('anki_tpls')||'{}');delete sv[n];localStorage.setItem('anki_tpls',JSON.stringify(sv));rSide();toast('🗑️');}
function rnd(){ph();var i=Math.floor(Math.random()*T.length);sT(i);S.frenchFontSize=+(1.5+Math.random()*3).toFixed(1);S.meaningFontSize=+(0.8+Math.random()*2).toFixed(1);S.borderRadius=Math.floor(Math.random()*50);S.cardPadding=Math.floor(8+Math.random()*52);S.cardGap=Math.floor(Math.random()*30);var fx=['none','neon','wave','sakura','ember','float','glow','bounce','pulse_border','gradient'];S.effect=fx[Math.floor(Math.random()*fx.length)];rSide();uP();toast('🎲 عشوائي!');}
function bC(){var c={};SB.forEach(function(s){if(s.fd)s.fd.forEach(function(f){if(f.id&&f.t!=='fx')c[f.id]=S[f.id];});});c.effect=S.effect;c.sectionOrder=S.sectionOrder.join(',');c.sectionVisibility=S.sectionVisibility;c.showBadge=S.showBadge;c.showUnitBadge=S.showUnitBadge;c.showMeaning=S.showMeaning;c.showPage=S.showPage;c.splitDirection=S.sp;return c;}
function expCSS(){var c=bC(),bg=c.cardBg2?'linear-gradient('+(c.bgGradientDir||'135deg')+','+c.cardBg+','+c.cardBg2+')':c.cardBg;var css='.card{background:'+bg+';color:'+(c.textColor||'#333')+';border-radius:'+(c.borderRadius||16)+'px;padding:'+(c.cardPadding||28)+'px}\n.french{font-size:'+(c.frenchFontSize||2.4)+'em;color:'+(c.frenchColor||'#1e293b')+'}\n.meaning{background:'+(c.meaningBg||'#eff6ff')+';border-radius:'+(c.meaningBorderRadius||16)+'px;color:'+(c.meaningColor||'#1e40af')+'}\n';navigator.clipboard.writeText(css).then(function(){toast('📋 نسخ!');}).catch(function(){toast('❌');});}
function expJSON(){var c=bC();var b=new Blob([JSON.stringify(c,null,2)],{type:'application/json'});var u=URL.createObjectURL(b);var a=document.createElement('a');a.href=u;a.download='anki-design.json';a.click();URL.revokeObjectURL(u);toast('💾 تم!');}
function cfj(){try{var c=JSON.parse(document.getElementById('jinp').value);ph();Object.keys(c).forEach(function(k){if(k in S)S[k]=c[k];});if(c.sectionOrder)S.sectionOrder=c.sectionOrder.split(',');if(c.sectionVisibility)S.sectionVisibility=c.sectionVisibility;if(c.effect)S.effect=c.effect;cm('mJson');rGal();rSide();uP();toast('📥 تم!');}catch(e){toast('❌ JSON غير صالح');}}
function share(){var c=bC();document.getElementById('surl').value=window.location.origin+window.location.pathname+'?config='+btoa(unescape(encodeURIComponent(JSON.stringify(c))));document.getElementById('mShare').classList.add('show');}
function cm(id){document.getElementById(id).classList.remove('show');}
function cps(){var inp=document.getElementById('surl');inp.select();document.execCommand('copy');toast('📋 نسخ!');}
function cmp(){var a=document.getElementById('cmpA');if(a.style.display==='none'||!a.style.display){a.style.display='block';var t1=T[S.sel]||T[0],t2=T[(S.sel+1)%T.length];a.innerHTML='<div class="cmp">'+[t1,t2].map(function(t,i){var bg=t.bg2?'linear-gradient(135deg,'+t.bg+','+t.bg2+')':t.bg;return '<div class="cbx"><div class="cbl">'+(i===0?'📐 الحالي':'🔄 بديل')+'</div><div style="background:'+bg+';padding:12px;min-height:140px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px"><div style="font-family:Inter;font-size:.9em;font-weight:900;color:'+t.fc+';direction:ltr">'+SA.f+'</div><div style="background:'+t.mb+';border:1px solid '+t.mbd+';border-radius:6px;padding:3px 10px;color:'+t.mc+';font-size:.68em">'+SA.a+'</div></div><div style="padding:3px;text-align:center;font-size:.62em;color:var(--tx2)">'+t.n+'</div></div>';}).join('')+'</div>';}else a.style.display='none';}
async function dl(dual){var ld=document.getElementById('dld'),info=document.getElementById('dli');ld.classList.add('on');info.textContent='';try{var c=bC();c.deckName=S.deckName||'📘 Français Bac 2021-2022';async function doDl(cfg,nm){var r=await fetch('/api/generate',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(cfg)});if(!r.ok){var e=await r.json().catch(function(){});throw new Error(e.error||'Failed');}var b=await r.blob(),u=URL.createObjectURL(b),a=document.createElement('a');a.href=u;a.download=nm;document.body.appendChild(a);a.click();document.body.removeChild(a);URL.revokeObjectURL(u);return b.size;}if(dual){var l=JSON.parse(JSON.stringify(c));l.cardBg='#fff';l.cardBg2='';l.frenchColor='#1e293b';l.meaningColor='#1e40af';l.textColor='#333';var s1=await doDl(l,(c.deckName||'d')+'_فاتح.apkg');var d=JSON.parse(JSON.stringify(c));d.cardBg='#0f172a';d.cardBg2='';d.frenchColor='#f8fafc';d.meaningColor='#93c5fd';d.textColor='#e2e8f0';d.meaningBg='rgba(30,41,59,.8)';d.meaningBorder='rgba(100,116,139,.3)';d.secBg='rgba(30,41,59,.6)';d.secBorder='rgba(100,116,139,.2)';d.secTextColor='#e2e8f0';d.labelColor='#94a3b8';var s2=await doDl(d,(c.deckName||'d')+'_داكن.apkg');info.textContent='✅ نسختين — '+((s1+s2)/1024/1024).toFixed(1)+' MB';}else{var sz=await doDl(c,(c.deckName||'d')+'.apkg');info.textContent='✅ '+((sz)/1024/1024).toFixed(1)+' MB';}}catch(e){info.textContent='❌ '+e.message;}ld.classList.remove('on');}
function lUrl(){var p=new URLSearchParams(window.location.search),cfg=p.get('config');if(!cfg)return;try{var j=JSON.parse(decodeURIComponent(escape(atob(cfg))));Object.keys(j).forEach(function(k){if(k in S)S[k]=j[k];});if(j.sectionOrder)S.sectionOrder=j.sectionOrder.split(',');if(j.sectionVisibility)S.sectionVisibility=j.sectionVisibility;if(j.effect)S.effect=j.effect;if(j.splitDirection)S.sp=j.splitDirection;}catch(e){}}
document.addEventListener('keydown',function(e){if(e.ctrlKey&&e.key==='z'){e.preventDefault();undo();}if(e.ctrlKey&&e.key==='y'){e.preventDefault();redo();}if(e.ctrlKey&&e.key==='s'){e.preventDefault();oS();}if(e.ctrlKey&&e.key==='d'){e.preventDefault();dl(false);}if(e.key==='Escape')document.querySelectorAll('.mb').forEach(function(m){m.classList.remove('show');});});
window.addEventListener('load',function(){lUrl();rSide();gFil();rGal();uP();uu();});

function showTab(id,el){document.querySelectorAll(".tab-content").forEach(function(t){t.classList.remove("active")});document.querySelectorAll(".tab-btn").forEach(function(t){t.classList.remove("active")});var el2=document.getElementById("tab-"+id);if(el2)el2.classList.add("active");if(el)el.classList.add("active");else{var btns=document.querySelectorAll(".tab-btn");var map={gallery:0,preview:1,customize:2,download:3};if(map[id]!==undefined&&btns[map[id]])btns[map[id]].classList.add("active")}if(id==="preview")uP();if(id==="download")rSts();window.scrollTo({top:0,behavior:"smooth"})}


// ===== NEW FUNCTIONS =====

// Theme Toggle
function toggleTheme(){
  var t=document.documentElement.getAttribute('data-theme');
  var next=t==='light'?'dark':'light';
  document.documentElement.setAttribute('data-theme',next);
  localStorage.setItem('anki_theme',next);
  document.getElementById('themeBtn').textContent=next==='dark'?'🌙':'☀️';
  toast(next==='dark'?'🌙 الوضع الداكن':'☀️ الوضع الفاتح');
}
(function(){var t=localStorage.getItem('anki_theme')||'dark';document.documentElement.setAttribute('data-theme',t);document.getElementById('themeBtn').textContent=t==='dark'?'🌙':'☀️';})();

// Show View (replaces go)
function showView(id,el){
  document.querySelectorAll('.view-content').forEach(function(v){v.classList.remove('active')});
  document.querySelectorAll('.view-btn').forEach(function(b){b.classList.remove('active')});
  var v=document.getElementById('v-'+id);
  if(v)v.classList.add('active');
  if(el)el.classList.add('active');
  else{
    var btns=document.querySelectorAll('.view-btn');
    var map={gallery:0,preview:1,customize:2,download:3};
    if(map[id]!==undefined&&btns[map[id]])btns[map[id]].classList.add('active');
  }
  if(id==='preview')uP();
  window.scrollTo({top:0,behavior:'smooth'});
}

// Override go to use showView
function go(id){
  var map={gal:'gallery',pv:'preview',dl:'download',cust:'customize'};
  showView(map[id]||id);
}

// Override rSide to target new div
var _origRSide=rSide;
rSide=function(){
  var el=document.getElementById('cust-panels');
  if(!el)return;
  // Build panels into customize-panels
  var h='';
  SB.forEach(function(s){
    h+='<div class="cp-sec"><div class="cp-hd open" onclick="ts(this)"><span>'+s.ic+' '+s.tt+'</span><span class="cp-ar">▼</span></div><div class="cp-bd open">';
    if(s.tp==='qa'){
      h+='<div class="cr"><div class="cl">⚡ ستايلات جاهزة</div><div class="qa-grid">';
      QA.forEach(function(q,i){h+='<button class="qa-btn" onclick="aq('+i+')" style="background:linear-gradient(135deg,'+q.bg+','+(q.bg2||q.bg)+');color:'+q.fc+'">'+q.nm+'</button>';});
      h+='</div><div class="bgrp"><button class="b" onclick="rd()" style="width:100%">🔄 إعادة تعيين كل شي</button></div></div>';
    } else if(s.tp==='vis'){
      SC.forEach(function(k){
        h+='<div class="tg '+(S.sectionVisibility[k]!==false?'on':'')+'" onclick="tsBool(''+k+'',this)"><div class="td">'+(S.sectionVisibility[k]!==false?'✓':'')+'</div><span class="tt">'+SE[k]+' '+SL[k]+'</span></div>';
      });
      h+='<div class="tg '+(S.showBadge?'on':'')+'" onclick="tsBool('showBadge',this)"><div class="td">'+(S.showBadge?'✓':'')+'</div><span class="tt">🏷️ إظهار الشارات</span></div>';
      h+='<div class="tg '+(S.showUnitBadge?'on':'')+'" onclick="tsBool('showUnitBadge',this)"><div class="td">'+(S.showUnitBadge?'✓':'')+'</div><span class="tt">📦 إظهار الوحدة</span></div>';
      h+='<div class="tg '+(S.showMeaning?'on':'')+'" onclick="tsBool('showMeaning',this)"><div class="td">'+(S.showMeaning?'✓':'')+'</div><span class="tt">🇸🇦 إظهار المعنى</span></div>';
      h+='<div class="tg '+(S.showPage?'on':'')+'" onclick="tsBool('showPage',this)"><div class="td">'+(S.showPage?'✓':'')+'</div><span class="tt">📄 إظهار الصفحة</span></div>';
    } else if(s.tp==='srt'){
      S.sectionOrder.forEach(function(k,i){
        h+='<div class="srt" draggable="true" ondragstart="dS(event,'+i+')" ondragover="event.preventDefault()" ondrop="dD(event,'+i+')"><span class="sn">'+(i+1)+'</span><span>'+SE[k]+' '+SL[k]+'</span></div>';
      });
    } else if(s.tp==='pal'){
      h+='<div class="cr"><div class="cl">🎨 أدخل لون أساسي</div><div class="ci"><input type="color" id="palIn" value="#6366f1" oninput="gPal(this.value)"><button class="ab" onclick="gPal(document.getElementById('palIn').value)">توليد</button></div><div id="palOut" style="margin-top:6px"></div></div>';
    } else if(s.tp==='tpl'){
      var sv=JSON.parse(localStorage.getItem('anki_tpls')||'{}'),ns=Object.keys(sv);
      h+='<div class="cr"><div class="cl">💾 القوالب المحفوظة</div>';
      if(ns.length){h+='<div class="tpl-saves">';
        ns.forEach(function(n){h+='<div class="tpl-save"><span>'+n+'</span><button class="ab" onclick="lT(''+n.replace(/'/g,"\\'")+'')">📂</button><button class="ab rd" onclick="dT(''+n.replace(/'/g,"\\'")+'')">🗑️</button></div>';});
        h+='</div>';} else h+='<div style="font-size:.66em;color:var(--tx3);text-align:center;padding:6px">لا توجد قوالب محفوظة</div>';
      h+='<div class="bgrp"><button class="b gn" onclick="oS()" style="width:100%">💾 حفظ التصميم الحالي</button><button class="b" onclick="document.getElementById('mJson').classList.add('show')" style="width:100%">📋 استيراد JSON</button><button class="b" onclick="expJSON()" style="width:100%">📤 تصدير JSON</button></div></div>';
    } else if(s.tp==='fx'){
      h+='<div class="cr"><div class="cl">✨ التأثيرات الحركية</div><div class="fxg">';
      FX.forEach(function(x){h+='<button class="fxb '+(S.effect===x.i?'on':'')+'" onclick="setFx(''+x.i+'')">'+x.e+' '+x.n+'</button>';});
      h+='</div></div>';
    } else if(s.fd){
      s.fd.forEach(function(f){
        if(f.t==='fx')return;
        h+='<div class="cr"><div class="cl">'+f.lb+'</div><div class="ci">';
        if(f.t==='c'){
          h+='<input type="color" value="'+(S[f.id]||'#ffffff')+'" oninput="setC(''+f.id+'',this.value)"><input type="text" class="mono" value="'+(S[f.id]||'')+'" onchange="setC(''+f.id+'',this.value)" style="max-width:90px">';
        } else if(f.t==='r'){
          h+='<div class="rg"><input type="range" min="'+f.mn+'" max="'+f.mx+'" step="'+f.st+'" value="'+(S[f.id]||f.d)+'" oninput="setR(''+f.id+'',this.value,''+f.u+'')"><span class="rv" id="rv-'+f.id+'">'+(S[f.id]||f.d)+f.u+'</span></div>';
        } else if(f.t==='s'){
          h+='<select class="mono" onchange="setS(''+f.id+'',this.value)">';
          f.o.forEach(function(o){h+='<option value="'+o+'" '+(S[f.id]===o||(!S[f.id]&&o===f.d)?'selected':'')+'>'+o+'</option>';});
          h+='</select>';
        } else if(f.t==='txt'){
          h+='<input type="text" value="'+(S[f.id]||f.d)+'" onchange="setT(''+f.id+'',this.value)" placeholder="'+f.lb+'">';
        } else if(f.t==='x'){
          h+='<input type="text" class="mono" value="'+(S[f.id]||'')+'" onchange="setC(''+f.id+'',this.value)" placeholder="مثل: 0 2px 10px rgba(0,0,0,.3)" style="font-size:.66em">';
        }
        h+='</div></div>';
      });
    }
    h+='</div></div>';
  });
  el.innerHTML=h;
}

// Smart Random
function smartRandom(){
  ph();
  // Pick a random template first
  var ri=Math.floor(Math.random()*T.length);
  sT(ri);
  // Then randomize some colors
  var hues=[0,30,60,120,180,210,270,300,330];
  var h=hues[Math.floor(Math.random()*hues.length)];
  function hsl2hex(h,s,l){
    s/=100;l/=100;
    var c=(1-Math.abs(2*l-1))*s;
    var x=c*(1-Math.abs((h/60)%2-1));
    var m=l-c/2;
    var r=0,g=0,b=0;
    if(h<60){r=c;g=x;}else if(h<120){r=x;g=c;}else if(h<180){g=c;b=x;}else if(h<240){g=x;b=c;}else if(h<300){r=x;b=c;}else{r=c;b=x;}
    return '#'+[r+m,g+m,b+m].map(function(v){return Math.round(v*255).toString(16).padStart(2,'0')}).join('');
  }
  var base=hsl2hex(h,60,50);
  var light=hsl2hex(h,50,85);
  var dark=hsl2hex(h,40,25);
  var accent=hsl2hex((h+180)%360,70,55);
  setC('cardBg',Math.random()>.5?base:dark);
  setC('frenchColor',Math.random()>.5?'#fff':light);
  setC('meaningColor',accent);
  setC('meaningBg',light+'33');
  setC('meaningBorder',accent+'66');
  // Pick random effect
  var effects=FX.filter(function(f){return f.i!=='none'});
  setFx(effects[Math.floor(Math.random()*effects.length)].i);
  rSide();uP();
  toast('🎲 تصميم ذكي جديد!');
}

// Save as Image
function saveAsImage(){
  var el=document.getElementById('pvF');
  if(!el){toast('❌ لا توجد معاينة');return;}
  toast('📸 جاري تحضير الصورة...');
  html2canvas(el,{scale:2,backgroundColor:null,useCORS:true}).then(function(canvas){
    var a=document.createElement('a');
    a.href=canvas.toDataURL('image/png');
    a.download='anki-card-design.png';
    document.body.appendChild(a);a.click();document.body.removeChild(a);
    toast('📸 تم حفظ الصورة!');
  }).catch(function(e){toast('❌ خطأ: '+e.message);});
}

// Fullscreen Browser
var fsIdx=0;
function openBrowser(){
  fsIdx=S.sel||0;
  fsShow();
  document.getElementById('fsBrowser').classList.add('show');
}
function closeBrowser(){document.getElementById('fsBrowser').classList.remove('show');}
function fsNav(d){
  fsIdx=(fsIdx+d+T.length)%T.length;
  fsShow();
}
function fsShow(){
  var t=T[fsIdx];
  var bg=t.bg2?'linear-gradient(135deg,'+t.bg+','+t.bg2+')':t.bg;
  document.getElementById('fsName').textContent=t.n;
  document.getElementById('fsEn').textContent=t.en;
  document.getElementById('fsCounter').textContent=(fsIdx+1)+' / '+T.length;
  // Build a large preview card
  var c='background:'+bg+';border-radius:16px;padding:28px;min-height:320px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;color:'+(t.tc||'#333')+';box-shadow:0 8px 40px rgba(0,0,0,.4);border:1px solid var(--bd)';
  var h='<div style="'+c+'">';
  h+='<div style="font-family:Inter;font-size:1.8em;font-weight:900;color:'+t.fc+';direction:ltr">'+SA.f+'</div>';
  h+='<div style="background:'+t.mb+';border:1px solid '+t.mbd+';border-radius:10px;padding:6px 20px;color:'+t.mc+';font-size:1em">'+SA.a+'</div>';
  h+='<div style="margin-top:8px"><span style="background:'+t.bnbg+';color:'+t.bnc+';padding:3px 10px;border-radius:6px;font-size:.7em;font-weight:700">N.</span> <span style="background:'+t.ubg+';color:'+t.uc+';padding:3px 10px;border-radius:6px;font-size:.7em;font-weight:700;border:1px solid '+t.ubd+'">Unit 1</span></div>';
  h+='</div>';
  document.getElementById('fsCard').innerHTML=h;
}

// Download as HTML
function dlAsHtml(){
  var c=bC();
  var bg=c.cardBg2?'linear-gradient('+(c.bgGradientDir||'135deg')+','+c.cardBg+','+c.cardBg2+')':c.cardBg;
  var html='<!DOCTYPE html><html lang="ar" dir="rtl"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0"><title>Anki Card</title><link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Arabic:wght@400;600;700;800;900&family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet"><style>body{margin:0;min-height:100vh;display:flex;align-items:center;justify-content:center;background:#111;font-family:"Inter","Noto Sans Arabic",sans-serif}.card{background:'+bg+';border-radius:'+(c.borderRadius||16)+'px;padding:'+(c.cardPadding||28)+'px;max-width:400px;width:90%;display:flex;flex-direction:column;align-items:center;gap:'+(c.cardGap||10)+'px;color:'+(c.textColor||'#333')+'}.french{font-size:'+(c.frenchFontSize||2.4)+'em;font-weight:'+(c.frenchFontWeight||900)+';color:'+(c.frenchColor||'#1e293b')+';direction:ltr;font-family:"Inter",sans-serif}.meaning{background:'+(c.meaningBg||'#eff6ff')+';border:'+(c.meaningBorderWidth||2)+'px solid '+(c.meaningBorder||'#bfdbfe')+';border-radius:'+(c.meaningBorderRadius||16)+'px;padding:8px 20px;color:'+(c.meaningColor||'#1e40af')+';font-size:'+(c.meaningFontSize||1.5)+'em;font-weight:'+(c.meaningFontWeight||800)+'}</style></head><body><div class="card"><div class="french">Un abonnement</div><div class="meaning">اشتراك</div></div></body></html>';
  var blob=new Blob([html],{type:'text/html'});
  var u=URL.createObjectURL(blob);
  var a=document.createElement('a');
  a.href=u;a.download='anki-card.html';
  document.body.appendChild(a);a.click();document.body.removeChild(a);
  URL.revokeObjectURL(u);
  toast('🌐 تم تحميل HTML!');
}

// Enhanced Toast with types
function toast(m,type){
  var t=document.getElementById('toast');
  t.textContent=m;
  t.className='toast show'+(type==='warn'?' warn':type==='err'?' err':'');
  clearTimeout(t._t);
  t._t=setTimeout(function(){t.className='toast';},2500);
}

// Right panel toggle for mobile
function togglePanel(){
  var p=document.querySelector('.right-panel');
  if(p)p.classList.toggle('open');
}

// Override window load
window.addEventListener('load',function(){
  lUrl();rSide();gFil();rGal();uP();uu();
  showView('gallery');
  // Auto-save every 30 seconds
  setInterval(function(){
    if(S.sel!==undefined){
      localStorage.setItem('anki_autosave',JSON.stringify(bC()));
    }
  },30000);
  // Restore auto-save
  var saved=localStorage.getItem('anki_autosave');
  if(saved){
    try{
      var c=JSON.parse(saved);
      Object.keys(c).forEach(function(k){if(k in S)S[k]=c[k];});
      if(c.sectionOrder)S.sectionOrder=c.sectionOrder.split(',');
      if(c.sectionVisibility)S.sectionVisibility=c.sectionVisibility;
      if(c.effect)S.effect=c.effect;
      rSide();gFil();rGal();uP();
    }catch(e){}
  }
});
</script>

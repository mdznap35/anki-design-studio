<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Anki Studio Pro — معرض التصميم الشامل</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Arabic:wght@400;600;700;800;900&family=Inter:wght@300;400;500;600;700;800;900&family=Fira+Code:wght@400&family=Poppins:wght@400;600;700;800;900&family=Playfair+Display:wght@400;700;900&family=Georgia&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#08080e;--s1:#0e0e1a;--s2:#161625;--s3:#1e1e35;
  --bd:#252550;--bd2:#35356a;--tx:#e8e8f8;--tx2:#8888bb;--tx3:#5555aa;
  --ac:#6366f1;--ac2:#818cf8;--ac3:rgba(99,102,241,.12);
  --gn:#22c55e;--rd:#ef4444;--pk:#ec4899;--pu:#a855f7;--or:#f59e0b;
  --r:14px;--shadow:0 4px 24px rgba(0,0,0,.4)
}
[data-theme="light"]{
  --bg:#f5f5fa;--s1:#fff;--s2:#f0f0f5;--s3:#e8e8f0;
  --bd:#d0d0e0;--bd2:#b0b0c0;--tx:#1a1a2e;--tx2:#555570;--tx3:#8888a0;
  --shadow:0 4px 24px rgba(0,0,0,.08)
}
@keyframes fadeUp{from{opacity:0;transform:translateY(12px)}to{opacity:1;transform:translateY(0)}}
@keyframes glow{0%,100%{box-shadow:0 0 6px var(--ac)}50%{box-shadow:0 0 20px var(--ac),0 0 40px rgba(99,102,241,.15)}}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-5px)}}
@keyframes cardIn{from{opacity:0;transform:scale(.92)}to{opacity:1;transform:scale(1)}}
@keyframes slideIn{from{opacity:0;transform:translateX(20px)}to{opacity:1;transform:translateX(0)}}
@keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.02)}}
@keyframes shimmer{0%{background-position:-200% 0}100%{background-position:200% 0}}
html{scroll-behavior:smooth}
body{font-family:'Inter','Noto Sans Arabic',sans-serif;background:var(--bg);color:var(--tx);min-height:100vh;overflow-x:hidden;transition:background .3s,color .3s}
::-webkit-scrollbar{width:6px}::-webkit-scrollbar-track{background:var(--s1)}::-webkit-scrollbar-thumb{background:var(--bd2);border-radius:3px}

/* ===== TOP NAV ===== */
.topnav{background:var(--s1);border-bottom:1px solid var(--bd);padding:10px 20px;display:flex;align-items:center;justify-content:space-between;gap:12px;position:sticky;top:0;z-index:100;backdrop-filter:blur(12px);transition:background .3s}
.brand{display:flex;align-items:center;gap:8px;font-size:1em;font-weight:900;white-space:nowrap}
.brand em{font-style:normal;background:linear-gradient(135deg,var(--ac2),var(--pu),var(--pk));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.top-actions{display:flex;gap:6px;flex-wrap:wrap;align-items:center}
.b{padding:7px 14px;border:1px solid var(--bd);border-radius:8px;background:var(--s2);color:var(--tx);cursor:pointer;font-size:.76em;font-weight:600;transition:all .2s;font-family:inherit;display:inline-flex;align-items:center;gap:5px;white-space:nowrap}
.b:hover{border-color:var(--ac);background:var(--s3)}
.b:disabled{opacity:.3;cursor:not-allowed}
.b.p{background:linear-gradient(135deg,var(--ac),var(--pu));color:#fff;border-color:var(--ac);padding:9px 20px}
.b.p:hover{box-shadow:0 4px 20px rgba(99,102,241,.4);transform:translateY(-1px)}
.b.sm{padding:4px 8px;font-size:.68em}
.b.gn{background:var(--gn);color:#fff;border-color:var(--gn)}

/* ===== MAIN LAYOUT ===== */
.main-layout{display:flex;height:calc(100vh - 46px)}
.left-panel{flex:1;overflow-y:auto;padding:20px;position:relative}
.right-panel{width:420px;min-width:420px;background:var(--s1);border-left:1px solid var(--bd);overflow-y:auto;transition:all .3s}
.right-panel.shut{width:0;min-width:0;border:none;overflow:hidden}
.rp-toggle{position:fixed;left:10px;bottom:10px;z-index:50;padding:8px 12px;border:1px solid var(--bd);border-radius:8px;background:var(--s1);color:var(--tx);cursor:pointer;font-size:.8em;display:none;box-shadow:var(--shadow)}

/* ===== VIEW SWITCHER ===== */
.view-bar{display:flex;gap:3px;background:var(--s1);padding:6px 20px;border-bottom:1px solid var(--bd);overflow-x:auto}
.view-btn{padding:8px 18px;border:none;background:none;color:var(--tx2);border-radius:8px;cursor:pointer;font-size:.78em;font-weight:600;transition:all .2s;font-family:inherit;white-space:nowrap;display:flex;align-items:center;gap:5px}
.view-btn:hover{color:var(--tx);background:var(--s2)}
.view-btn.active{color:#fff;background:var(--ac)}
.view-content{display:none;animation:fadeUp .3s ease}
.view-content.active{display:block}

/* ===== GALLERY ===== */
.gal-header{display:flex;align-items:center;gap:10px;margin-bottom:16px;flex-wrap:wrap}
.search{flex:1;min-width:180px;background:var(--s1);border:1px solid var(--bd);border-radius:10px;padding:9px 14px;display:flex;align-items:center;gap:8px;transition:border-color .2s}
.search:focus-within{border-color:var(--ac)}
.search input{flex:1;background:none;border:none;color:var(--tx);font-size:.85em;font-family:inherit;outline:none}
.search input::placeholder{color:var(--tx3)}
.chips{display:flex;gap:5px;flex-wrap:wrap}
.chip{padding:5px 12px;border:1px solid var(--bd);border-radius:18px;background:var(--s1);color:var(--tx2);font-size:.7em;font-weight:600;cursor:pointer;transition:all .2s;font-family:inherit}
.chip:hover{border-color:var(--ac);color:var(--ac2)}
.chip.on{border-color:var(--ac);background:var(--ac3);color:var(--ac2)}
.gal-count{font-size:.72em;color:var(--tx2);white-space:nowrap}
.gal-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(195px,1fr));gap:12px}
.gal-card{background:var(--s1);border:2px solid var(--bd);border-radius:var(--r);cursor:pointer;transition:all .3s;overflow:hidden;position:relative;animation:cardIn .3s ease both}
.gal-card:hover{border-color:var(--ac);transform:translateY(-4px);box-shadow:0 8px 28px rgba(99,102,241,.12)}
.gal-card.sel{border-color:var(--gn);box-shadow:0 0 20px rgba(34,197,94,.12);animation:glow 2s ease infinite}
.gal-card.sel::after{content:'✓ مختار';position:absolute;top:6px;left:6px;background:var(--gn);color:#fff;padding:2px 10px;border-radius:12px;font-size:.6em;font-weight:700;z-index:5}
.gal-card .fav{position:absolute;top:6px;right:6px;width:26px;height:26px;border-radius:50%;background:rgba(0,0,0,.5);border:none;color:#fff;font-size:11px;cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:5;transition:all .2s;opacity:0}
.gal-card:hover .fav{opacity:1}
.gal-card .fav.on{background:var(--pk);opacity:1}
.gal-pv{height:150px;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:10px;overflow:hidden}
.gal-inf{padding:8px 12px;border-top:1px solid var(--bd);display:flex;justify-content:space-between;align-items:center}
.gal-nm{font-weight:700;font-size:.72em}
.gal-en{font-size:.54em;color:var(--tx2);direction:ltr;display:block;margin-top:1px}
.gal-cat{font-size:.48em;padding:2px 7px;border-radius:5px;background:var(--s2);color:var(--tx2)}

/* ===== FULLSCREEN BROWSER ===== */
.fs-browser{position:fixed;inset:0;z-index:200;background:var(--bg);display:none;flex-direction:column;animation:fadeUp .3s ease}
.fs-browser.show{display:flex}
.fs-top{display:flex;align-items:center;justify-content:space-between;padding:12px 20px;background:var(--s1);border-bottom:1px solid var(--bd)}
.fs-close{padding:6px 14px;border:1px solid var(--bd);border-radius:8px;background:var(--s2);color:var(--tx);cursor:pointer;font-size:.78em;font-weight:600;font-family:inherit}
.fs-close:hover{border-color:var(--rd);color:var(--rd)}
.fs-body{flex:1;display:flex;align-items:center;justify-content:center;position:relative;overflow:hidden}
.fs-card{max-width:420px;width:90%;animation:fadeUp .3s ease}
.fs-nav{position:absolute;top:50%;transform:translateY(-50%);padding:12px 16px;border:1px solid var(--bd);border-radius:50%;background:var(--s1);color:var(--tx);cursor:pointer;font-size:1.2em;z-index:5;transition:all .2s}
.fs-nav:hover{border-color:var(--ac);background:var(--s2)}
.fs-nav.prev{right:20px}
.fs-nav.next{left:20px}
.fs-bottom{display:flex;align-items:center;justify-content:center;gap:12px;padding:14px 20px;background:var(--s1);border-top:1px solid var(--bd)}
.fs-info{text-align:center}
.fs-info h3{font-size:.9em;font-weight:800}
.fs-info p{font-size:.72em;color:var(--tx2)}
.fs-counter{font-size:.72em;color:var(--tx2);min-width:60px;text-align:center}

/* ===== PREVIEW ===== */
.pv-wrap{max-width:440px;margin:0 auto}
.pv-box{border-radius:14px;overflow:hidden;box-shadow:var(--shadow);border:1px solid var(--bd);transition:all .3s}
.scr-btns{display:flex;gap:6px;justify-content:center;margin-bottom:14px}
.scr-btn{padding:7px 14px;border:2px solid var(--bd);border-radius:8px;background:none;color:var(--tx2);cursor:pointer;font-size:.74em;font-weight:600;font-family:inherit;transition:all .2s}
.scr-btn:hover{border-color:var(--ac);color:var(--tx)}
.scr-btn.on{border-color:var(--gn);color:var(--gn);background:rgba(34,197,94,.06)}
.fw{perspective:1000px;width:100%;max-width:420px;margin:0 auto;cursor:pointer}
.fi{position:relative;width:100%;transition:transform .6s cubic-bezier(.4,0,.2,1);transform-style:preserve-3d}
.fi.flipped{transform:rotateY(180deg)}
.ff,.fbk{backface-visibility:hidden;width:100%}
.fbk{position:absolute;top:0;left:0;transform:rotateY(180deg)}
.pv-actions{display:flex;gap:8px;justify-content:center;margin:14px 0;flex-wrap:wrap}

/* ===== CUSTOMIZE PANELS ===== */
.cp-sec{background:var(--s1);border:1px solid var(--bd);border-radius:var(--r);overflow:hidden;margin-bottom:8px}
.cp-hd{padding:11px 14px;display:flex;align-items:center;justify-content:space-between;cursor:pointer;transition:background .2s;font-size:.8em;font-weight:700}
.cp-hd:hover{background:var(--s2)}
.cp-hd.open{border-bottom:1px solid var(--bd)}
.cp-ar{font-size:.5em;color:var(--tx2);transition:transform .2s}
.cp-hd.open .cp-ar{transform:rotate(180deg)}
.cp-bd{padding:10px 14px;display:none;flex-direction:column;gap:7px}
.cp-bd.open{display:flex}
.cr{display:flex;flex-direction:column;gap:3px}
.cl{font-size:.64em;font-weight:600;color:var(--tx2);text-transform:uppercase;letter-spacing:.3px}
.ci{display:flex;gap:5px;align-items:center}
.ci input[type=color]{width:32px;height:24px;border:2px solid var(--bd);border-radius:5px;cursor:pointer;background:none;padding:0}
.ci input[type=color]::-webkit-color-swatch-wrapper{padding:2px}
.ci input[type=color]::-webkit-color-swatch{border-radius:2px;border:none}
.ci input[type=text],.ci input[type=number],.ci select,.ci textarea{flex:1;background:var(--s2);border:1px solid var(--bd);border-radius:6px;padding:6px 10px;color:var(--tx);font-size:.74em;font-family:inherit}
.ci input:focus,.ci select:focus,.ci textarea:focus{outline:none;border-color:var(--ac)}
.ci .mono{font-family:'Fira Code',monospace}
.ci .rg{display:flex;align-items:center;gap:6px;flex:1}
.ci .rg input[type=range]{flex:1;accent-color:var(--ac);height:3px}
.ci .rv{font-size:.58em;color:var(--ac2);min-width:30px;text-align:center;font-weight:600}
.tg{display:flex;align-items:center;gap:8px;padding:7px 10px;background:var(--s2);border-radius:7px;cursor:pointer;transition:all .2s;border:1px solid transparent}
.tg:hover{border-color:var(--bd2)}
.tg.on{background:rgba(34,197,94,.06);border-color:rgba(34,197,94,.25)}
.tg .td{width:16px;height:16px;border-radius:3px;border:2px solid var(--bd);display:flex;align-items:center;justify-content:center;font-size:9px;transition:all .2s;flex-shrink:0}
.tg.on .td{background:var(--gn);border-color:var(--gn);color:#fff}
.tg .tt{font-size:.7em;font-weight:600}
.fxg{display:grid;grid-template-columns:repeat(auto-fill,minmax(72px,1fr));gap:3px}
.fxb{padding:5px 2px;border:1px solid var(--bd);border-radius:5px;background:var(--s2);color:var(--tx2);font-size:.54em;font-weight:600;cursor:pointer;transition:all .2s;text-align:center;font-family:inherit}
.fxb:hover{border-color:var(--ac);color:var(--tx)}
.fxb.on{border-color:var(--ac);background:var(--ac3);color:var(--ac2)}
.srt{display:flex;align-items:center;gap:7px;padding:7px 10px;background:var(--s2);border-radius:5px;cursor:grab;transition:all .2s;border:1px solid transparent;font-size:.7em}
.srt:hover{border-color:var(--ac)}
.srt .sn{width:18px;height:18px;border-radius:50%;background:var(--ac);color:#fff;display:flex;align-items:center;justify-content:center;font-size:.48em;font-weight:700;flex-shrink:0}
.qa-grid{display:grid;grid-template-columns:1fr 1fr;gap:5px}
.qa-btn{padding:8px;border:1px solid var(--bd);border-radius:7px;background:var(--s2);color:var(--tx2);font-size:.66em;font-weight:600;cursor:pointer;transition:all .2s;font-family:inherit;text-align:center}
.qa-btn:hover{border-color:var(--ac);color:var(--ac2);transform:translateY(-1px)}
.tpl-saves{display:flex;flex-direction:column;gap:3px}
.tpl-save{display:flex;align-items:center;gap:5px;padding:5px 8px;background:var(--s2);border-radius:5px;font-size:.66em}
.tpl-save span{flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.ab{padding:4px 8px;border:1px solid var(--bd);border-radius:5px;background:var(--s2);color:var(--tx2);cursor:pointer;font-size:.62em;font-weight:600;transition:all .2s;font-family:inherit}
.ab:hover{border-color:var(--ac);color:var(--ac2)}
.ab.gn{background:var(--gn);color:#fff;border-color:var(--gn)}
.ab.rd{color:var(--rd)}.ab.rd:hover{border-color:var(--rd)}
.bgrp{display:flex;flex-direction:column;gap:4px;margin-top:6px}
.bgrp .b{width:100%;justify-content:center;font-size:.74em;padding:8px}

/* ===== DOWNLOAD ===== */
.dl-section{text-align:center;padding:28px;background:linear-gradient(135deg,rgba(99,102,241,.04),rgba(168,85,247,.04));border-radius:16px;border:1px solid var(--bd)}
.dl-btns{display:flex;gap:8px;justify-content:center;flex-wrap:wrap;margin:14px 0}
.spw{background:var(--s1);border:1px solid var(--bd);border-radius:8px;padding:10px;text-align:center;margin:10px 0}
.spt{font-size:.78em;font-weight:700;margin-bottom:6px}
.sps{display:flex;gap:6px;justify-content:center}
.spb{padding:7px 16px;border:2px solid var(--bd);border-radius:8px;background:var(--s2);color:var(--tx);cursor:pointer;font-size:.7em;font-weight:600;font-family:inherit;transition:all .2s}
.spb:hover{border-color:var(--ac)}
.spb.on{border-color:var(--gn);background:rgba(34,197,94,.06);color:var(--gn)}
.ld{display:none;text-align:center;padding:14px}.ld.on{display:block}
.spn{width:28px;height:28px;border:3px solid var(--bd);border-top-color:var(--ac);border-radius:50%;animation:spin .8s linear infinite;margin:0 auto 8px}
.dl-result{color:var(--tx2);margin-top:8px;font-size:.76em}

/* ===== MODAL ===== */
.modal{position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:150;display:none;align-items:center;justify-content:center;backdrop-filter:blur(4px)}
.modal.show{display:flex}
.modal-box{background:var(--s1);border:1px solid var(--bd);border-radius:14px;padding:20px;max-width:440px;width:90%;max-height:80vh;overflow-y:auto;box-shadow:0 8px 40px rgba(0,0,0,.5);animation:fadeUp .3s ease}
.modal-x{float:left;cursor:pointer;font-size:1.2em;color:var(--tx2);transition:color .2s;background:none;border:none}.modal-x:hover{color:var(--tx)}
.modal-box h3{margin-bottom:6px;font-size:.92em}
.modal-box p{font-size:.74em;color:var(--tx2);margin-bottom:10px}

/* ===== TOAST / NOTIFICATIONS ===== */
.toast{position:fixed;bottom:16px;left:50%;transform:translateX(-50%);z-index:999;background:var(--gn);color:#fff;padding:8px 18px;border-radius:10px;font-weight:700;font-size:.78em;box-shadow:0 4px 16px rgba(34,197,94,.3);opacity:0;transition:all .3s;pointer-events:none;max-width:90%;text-align:center}
.toast.show{opacity:1;transform:translateX(-50%) translateY(-4px)}
.toast.warn{background:var(--or);box-shadow:0 4px 16px rgba(245,158,11,.3)}
.toast.err{background:var(--rd);box-shadow:0 4px 16px rgba(239,68,68,.3)}

/* ===== THEME TOGGLE ===== */
.theme-btn{width:34px;height:34px;border-radius:50%;border:1px solid var(--bd);background:var(--s2);color:var(--tx2);cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:.85em;transition:all .2s}
.theme-btn:hover{border-color:var(--ac);color:var(--ac2)}

/* ===== EMPTY STATE ===== */
.emp{text-align:center;padding:40px 20px;color:var(--tx2)}
.emp .ic{font-size:2.2em;display:block;margin-bottom:8px;opacity:.4;animation:float 3s ease-in-out infinite}

/* ===== RESPONSIVE ===== */
@media(max-width:900px){
  .right-panel{position:fixed;top:46px;right:0;bottom:0;width:360px;z-index:40;transform:translateX(100%);transition:transform .3s}
  .right-panel.open{transform:translateX(0)}
  .rp-toggle{display:flex}
  .gal-grid{grid-template-columns:1fr 1fr;gap:8px}
  .gal-pv{height:120px}
}
@media(max-width:600px){
  .topnav{padding:8px 12px}
  .view-bar{padding:4px 12px}
  .view-btn{padding:6px 12px;font-size:.7em}
  .gal-grid{grid-template-columns:1fr 1fr;gap:6px}
  .gal-pv{height:100px}
  .dl-btns{flex-direction:column;align-items:center}
}
</style>
</head>
<body>

<!-- TOP NAV -->
<div class="topnav">
  <div class="brand">🎨 <em>Anki Studio Pro</em></div>
  <div class="top-actions">
    <button class="b sm" onclick="undo()" id="ub" disabled>↩️</button>
    <button class="b sm" onclick="redo()" id="rb" disabled>↪️</button>
    <button class="b sm" onclick="smartRandom()">🎲 ذكي</button>
    <button class="b sm" onclick="oS()">💾</button>
    <button class="theme-btn" onclick="toggleTheme()" id="themeBtn" title="تبديل الوضع">🌙</button>
    <button class="b p" onclick="dl(false)">⬇️ حمّل</button>
  </div>
</div>

<!-- VIEW BAR -->
<div class="view-bar">
  <button class="view-btn active" onclick="showView('gallery',this)">🎨 المعرض</button>
  <button class="view-btn" onclick="showView('preview',this)">👁️ معاينة</button>
  <button class="view-btn" onclick="showView('customize',this)">⚙️ تخصيص</button>
  <button class="view-btn" onclick="showView('download',this)">📦 تحميل</button>
</div>

<!-- VIEW: GALLERY -->
<div class="view-content active" id="v-gallery">
  <div class="gal-header">
    <div class="search">🔍 <input type="text" id="gsrch" placeholder="ابحث عن قالب..." oninput="rGal()"></div>
    <div class="chips" id="gfil"></div>
    <div class="gal-count" id="gct"></div>
  </div>
  <div class="gal-grid" id="ggrid"></div>
</div>

<!-- VIEW: PREVIEW -->
<div class="view-content" id="v-preview">
  <div style="text-align:center;margin-bottom:14px">
    <div style="font-size:1.1em;font-weight:800;margin-bottom:3px">👁️ معاينة مباشرة</div>
    <div style="font-size:.78em;color:var(--tx2)">اضغط البطاقة لقلبها — غيّر الإعدادات وشوف النتيجة فوراً</div>
  </div>
  <div class="scr-btns">
    <button class="scr-btn on" onclick="scr2('mob',this)">📱 جوال</button>
    <button class="scr-btn" onclick="scr2('tab',this)">📱 تابلت</button>
    <button class="scr-btn" onclick="scr2('desk',this)">💻 كمبيوتر</button>
  </div>
  <div class="pv-wrap">
    <div class="fw" onclick="flip()">
      <div class="fi" id="fip">
        <div class="ff"><div class="pv-box" id="pvF"></div></div>
        <div class="fbk"><div class="pv-box" id="pvB"></div></div>
      </div>
    </div>
  </div>
  <div class="pv-actions">
    <button class="b" onclick="openBrowser()">🖼️ تصفّح بالشاشة الكاملة</button>
    <button class="b" onclick="cmp()">📊 مقارنة</button>
    <button class="b" onclick="saveAsImage()">📸 حفظ كصورة</button>
    <button class="b p" onclick="dl(false)">⬇️ حمّل الآن</button>
  </div>
  <div id="cmpA" style="display:none"></div>
</div>

<!-- VIEW: CUSTOMIZE -->
<div class="view-content" id="v-customize">
  <div style="text-align:center;margin-bottom:14px">
    <div style="font-size:1.1em;font-weight:800;margin-bottom:3px">⚙️ تخصيص كامل</div>
    <div style="font-size:.78em;color:var(--tx2)">غيّر كل تفصيلة — شوف النتيجة فوراً بالمعاينة</div>
  </div>
  <div id="cust-panels"></div>
</div>

<!-- VIEW: DOWNLOAD -->
<div class="view-content" id="v-download">
  <div class="dl-section">
    <div style="font-size:2.8em;margin-bottom:8px;animation:float 3s ease-in-out infinite">📦</div>
    <div style="font-size:1.05em;font-weight:800;margin-bottom:4px">حمّل رزمة Anki</div>
    <div style="font-size:.78em;color:var(--tx2);margin-bottom:14px">الكلمات الفرنسية بالتصميم اللي صممته</div>
    <div class="spw"><div class="spt">🔀 تقسيم البطاقات</div><div class="sps"><button class="spb on" onclick="setSp('unified',this)">📘 موحدة</button><button class="spb" onclick="setSp('separate',this)">🔀 منفصلة</button></div></div>
    <div class="dl-btns">
      <button class="b p" onclick="dl(false)">⬇️ تحميل .apkg</button>
      <button class="b" onclick="dlAsHtml()">🌐 تحميل كـ HTML</button>
      <button class="b" onclick="expCSS()">📋 نسخ CSS</button>
      <button class="b" onclick="expJSON()">💾 تصدير JSON</button>
    </div>
    <div class="ld" id="dld"><div class="spn"></div><p style="color:var(--ac2);font-weight:600;font-size:.82em">جاري التوليد...</p></div>
    <div class="dl-result" id="dli"></div>
  </div>
</div>

<!-- FULLSCREEN BROWSER -->
<div class="fs-browser" id="fsBrowser">
  <div class="fs-top">
    <div class="fs-info"><h3 id="fsName">—</h3><p id="fsEn">—</p></div>
    <div style="display:flex;gap:8px;align-items:center">
      <span class="fs-counter" id="fsCounter">1 / 50</span>
      <button class="b" onclick="sT(fsIdx)">✅ اختر هذا القالب</button>
      <button class="fs-close" onclick="closeBrowser()">✕ إغلاق</button>
    </div>
  </div>
  <div class="fs-body">
    <button class="fs-nav prev" onclick="fsNav(-1)">◀</button>
    <div class="fs-card" id="fsCard"></div>
    <button class="fs-nav next" onclick="fsNav(1)">▶</button>
  </div>
  <div class="fs-bottom">
    <button class="b" onclick="fsNav(-1)">◀ السابق</button>
    <button class="b p" onclick="sT(fsIdx);closeBrowser();showView('customize')">✅ اختر وخصّص</button>
    <button class="b" onclick="fsNav(1)">التالي ▶</button>
  </div>
</div>

<!-- MODALS -->
<div class="modal" id="mSave"><div class="modal-box"><button class="modal-x" onclick="cm('mSave')">&times;</button><h3>💾 حفظ التصميم</h3><p>أعط التصميم اسم لاسترجاعه لاحقاً</p><input type="text" id="tname" placeholder="اسم التصميم..." style="width:100%;padding:10px;margin:8px 0;background:var(--s2);border:1px solid var(--bd);border-radius:6px;color:var(--tx);font-family:inherit"><div style="text-align:center"><button class="b gn" onclick="cfs()" style="width:100%;justify-content:center">💾 حفظ</button></div></div></div>
<div class="modal" id="mJson"><div class="modal-box"><button class="modal-x" onclick="cm('mJson')">&times;</button><h3>📋 استيراد إعدادات</h3><p>الصق إعدادات التصميم بصيغة JSON</p><textarea id="jinp" style="width:100%;min-height:100px;padding:10px;margin:8px 0;background:var(--s2);border:1px solid var(--bd);border-radius:6px;color:var(--tx);font-family:'Fira Code',monospace;direction:ltr" placeholder='{"cardBg":"#ffffff",...}'></textarea><div style="text-align:center"><button class="b p" onclick="cfj()" style="width:100%;justify-content:center">📥 استيراد</button></div></div></div>
<div class="toast" id="toast"></div>

<button class="rp-toggle" id="rpToggle" onclick="togglePanel()">⚙️</button>


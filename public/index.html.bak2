function rSts(){document.getElementById('dsts').innerHTML='<div class="sti"><div class="stv">3,487</div><div class="stl">كلمة</div></div><div class="sti"><div class="stv">735</div><div class="stl">مهمة</div></div><div class="sti"><div class="stv">6</div><div class="stl">وحدات</div></div><div class="sti"><div class="stv">~300KB</div><div class="stl">حجم متوقع</div></div><div class="sti"><div class="stv">'+T.length+'</div><div class="stl">قالب</div></div>';}
function undo(){if(!HP.length)return;HF.push(JSON.stringify(S));Object.assign(S,JSON.parse(HP.pop()));rGal();rSide();uP();uu();}

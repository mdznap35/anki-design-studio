<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Anki Studio Pro</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Arabic:wght@400;600;700;800;900&family=Inter:wght@300;400;500;600;700;800;900&family=Fira+Code:wght@400&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{--bg:#08080f;--s1:#0e0e1a;--s2:#14142a;--s3:#1c1c3a;--bd:#252550;--bd2:#35356a;--tx:#e8e8f8;--tx2:#8888bb;--tx3:#5555aa;--ac:#6366f1;--ac2:#818cf8;--gn:#22c55e;--rd:#ef4444;--pk:#ec4899;--pu:#a855f7;--r:12px;--shadow:0 4px 20px rgba(0,0,0,.3)}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
@keyframes glow{0%,100%{box-shadow:0 0 4px var(--ac)}50%{box-shadow:0 0 16px var(--ac),0 0 32px rgba(99,102,241,.25)}}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-4px)}}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes gradFlow{0%{background-position:0% 50%}50%{background-position:100% 50%}100%{background-position:0% 50%}}
@keyframes cardIn{from{opacity:0;transform:scale(.92)}to{opacity:1;transform:scale(1)}}
@keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.03)}}
html{scroll-behavior:smooth}
body{font-family:'Inter','Noto Sans Arabic',sans-serif;background:var(--bg);color:var(--tx);height:100vh;overflow:hidden;animation:fadeIn .5s ease}
::-webkit-scrollbar{width:5px}::-webkit-scrollbar-track{background:var(--s1)}::-webkit-scrollbar-thumb{background:var(--bd2);border-radius:3px}

/* ===== TOPBAR ===== */
.topbar{height:52px;background:rgba(8,8,15,.95);backdrop-filter:blur(16px);border-bottom:1px solid var(--bd);display:flex;align-items:center;padding:0 16px;gap:12px;flex-shrink:0}
.logo{font-weight:900;font-size:.9em;white-space:nowrap;display:flex;align-items:center;gap:6px}
.logo i{font-style:normal;font-size:1.2em;animation:float 3s ease-in-out infinite}
.logo b{background:linear-gradient(135deg,var(--ac2),var(--pu),var(--pk));background-size:200% 200%;-webkit-background-clip:text;-webkit-text-fill-color:transparent;animation:gradFlow 4s ease infinite}
.tabs{display:flex;gap:2px;background:var(--s2);border-radius:8px;padding:3px;border:1px solid var(--bd);margin:0 auto}
.tab{padding:6px 14px;border:none;background:none;color:var(--tx2);border-radius:6px;cursor:pointer;font-size:.72em;font-weight:600;transition:all .2s;font-family:inherit;white-space:nowrap;display:flex;align-items:center;gap:5px}
.tab:hover{color:var(--tx);background:var(--s3)}.tab.on{color:#fff;background:var(--ac)}
.top-actions{display:flex;gap:6px;align-items:center}
.abtn{padding:5px 10px;border:1px solid var(--bd);border-radius:6px;background:var(--s2);color:var(--tx2);cursor:pointer;font-size:.68em;font-weight:600;transition:all .2s;font-family:inherit;white-space:nowrap;display:flex;align-items:center;gap:4px}
.abtn:hover{border-color:var(--ac);color:var(--ac2)}.abtn:disabled{opacity:.3;cursor:not-allowed}
.abtn.ac{background:linear-gradient(135deg,var(--ac),var(--pu));color:#fff;border-color:var(--ac)}
.abtn.gn{background:var(--gn);color:#fff;border-color:var(--gn)}
.abtn.rd{color:var(--rd)}.abtn.rd:hover{border-color:var(--rd)}
.abtn.sm{padding:4px 8px;font-size:.62em}
.sb-tog{display:none;padding:5px 8px;border:1px solid var(--bd);border-radius:6px;background:var(--s2);color:var(--tx2);cursor:pointer;font-size:.9em}

/* ===== LAYOUT ===== */
.app{display:flex;height:calc(100vh - 52px)}
.side{width:320px;min-width:320px;background:var(--s1);border-left:1px solid var(--bd);overflow-y:auto;overflow-x:hidden;padding:8px;display:flex;flex-direction:column;gap:6px;transition:all .3s}
.side::-webkit-scrollbar{width:3px}
.side.shut{width:0;min-width:0;padding:0;border:none;overflow:hidden}
.main{flex:1;overflow-y:auto;padding:16px;position:relative}

/* ===== SIDEBAR ===== */
.ss{background:var(--s2);border:1px solid var(--bd);border-radius:var(--r);overflow:hidden}
.sh{padding:10px 14px;display:flex;align-items:center;justify-content:space-between;cursor:pointer;transition:background .2s;font-size:.78em;font-weight:700}
.sh:hover{background:var(--s3)}.sh.open{border-bottom:1px solid var(--bd)}
.sh span:first-child{display:flex;align-items:center;gap:6px}
.sa{font-size:.5em;transition:transform .2s;color:var(--tx2)}.sh.open .sa{transform:rotate(180deg)}
.sb{padding:10px 14px;display:none;flex-direction:column;gap:8px}.sb.open{display:flex}
.sc{display:flex;flex-direction:column;gap:4px}
.sl{font-size:.62em;font-weight:600;color:var(--tx2);text-transform:uppercase;letter-spacing:.5px;margin-bottom:2px}
.sr{display:flex;gap:4px;align-items:center}
.clr{width:30px;height:24px;border:2px solid var(--bd);border-radius:4px;cursor:pointer;background:none;padding:0}
.clr::-webkit-color-swatch-wrapper{padding:2px}.clr::-webkit-color-swatch{border-radius:2px;border:none}
.hx{flex:1;background:var(--s3);border:1px solid var(--bd);border-radius:4px;padding:5px 8px;color:var(--tx);font-size:.7em;font-family:'Fira Code',monospace}
.hx:focus,.tx:focus,.sl2:focus{outline:none;border-color:var(--ac)}
.rg{display:flex;align-items:center;gap:4px;flex:1}
.rg input[type=range]{flex:1;accent-color:var(--ac);height:3px}
.rv{font-size:.56em;color:var(--ac2);min-width:28px;text-align:center;font-weight:600}
.sl2{flex:1;background:var(--s3);border:1px solid var(--bd);border-radius:4px;padding:5px 8px;color:var(--tx);font-size:.7em;font-family:inherit}
.tx{flex:1;background:var(--s3);border:1px solid var(--bd);border-radius:4px;padding:5px 8px;color:var(--tx);font-size:.7em;font-family:inherit}
.tg{display:flex;align-items:center;gap:8px;padding:6px 10px;background:var(--s3);border-radius:6px;cursor:pointer;transition:all .2s;border:1px solid transparent}
.tg:hover{border-color:var(--bd2)}.tg.on{background:rgba(34,197,94,.08);border-color:rgba(34,197,94,.3)}
.td{width:16px;height:16px;border-radius:4px;border:2px solid var(--bd);display:flex;align-items:center;justify-content:center;font-size:9px;transition:all .2s;flex-shrink:0}
.tg.on .td{background:var(--gn);border-color:var(--gn);color:#fff}
.tl{font-size:.7em;font-weight:600}
.fxg{display:grid;grid-template-columns:repeat(5,1fr);gap:3px}
.fxb{padding:4px 2px;border:1px solid var(--bd);border-radius:4px;background:var(--s3);color:var(--tx2);font-size:.52em;font-weight:600;cursor:pointer;transition:all .2s;text-align:center;font-family:inherit}
.fxb:hover{border-color:var(--ac);color:var(--tx)}.fxb.on{border-color:var(--ac);background:rgba(99,102,241,.12);color:var(--ac2)}
.srt{display:flex;align-items:center;gap:6px;padding:5px 8px;background:var(--s3);border-radius:5px;cursor:grab;transition:all .2s;border:1px solid transparent;font-size:.7em}
.srt:hover{border-color:var(--ac)}.srt.dragging{opacity:.4}
.srn{width:18px;height:18px;border-radius:50%;background:var(--ac);color:#fff;display:flex;align-items:center;justify-content:center;font-size:.5em;font-weight:700;flex-shrink:0}
.fp{padding:6px 10px;background:var(--s3);border-radius:5px;text-align:center;direction:ltr}
.fp .s{font-size:.82em;font-weight:700;margin-bottom:2px}.fp .n{font-size:.52em;color:var(--tx2)}
.qag{display:grid;grid-template-columns:1fr 1fr;gap:4px;margin-top:6px}
.qab{padding:6px;border:1px solid var(--bd);border-radius:6px;background:var(--s2);color:var(--tx2);font-size:.64em;font-weight:600;cursor:pointer;transition:all .2s;font-family:inherit;text-align:center}
.qab:hover{border-color:var(--ac);color:var(--ac2);transform:translateY(-1px)}

/* ===== GALLERY ===== */
.gh{display:flex;align-items:center;gap:8px;margin-bottom:14px;flex-wrap:wrap}
.gs{flex:1;min-width:160px;background:var(--s1);border:1px solid var(--bd);border-radius:8px;padding:6px 10px;color:var(--tx);font-size:.76em;display:flex;align-items:center;gap:6px;transition:border-color .2s}
.gs:focus-within{border-color:var(--ac)}
.gs input{flex:1;background:none;border:none;color:var(--tx);font-size:1em;font-family:inherit;outline:none}
.gs input::placeholder{color:var(--tx3)}
.gf{display:flex;gap:3px;flex-wrap:wrap}
.gb{padding:4px 10px;border:1px solid var(--bd);border-radius:10px;background:var(--s1);color:var(--tx2);font-size:.64em;font-weight:600;cursor:pointer;transition:all .2s;font-family:inherit}
.gb:hover{border-color:var(--ac);color:var(--ac2)}.gb.on{border-color:var(--ac);background:rgba(99,102,241,.1);color:var(--ac2)}
.gc{font-size:.66em;color:var(--tx2);white-space:nowrap}
.gg{display:grid;grid-template-columns:repeat(auto-fill,minmax(190px,1fr));gap:10px}
.tc{background:var(--s1);border:2px solid var(--bd);border-radius:var(--r);cursor:pointer;transition:all .3s;overflow:hidden;position:relative;animation:cardIn .3s ease both}
.tc:hover{border-color:var(--ac);transform:translateY(-4px);box-shadow:0 8px 24px rgba(99,102,241,.12)}
.tc.sel{border-color:var(--gn);box-shadow:0 0 16px rgba(34,197,94,.15);animation:glow 2s ease infinite}
.tc.sel::after{content:'✓';position:absolute;top:6px;left:6px;background:var(--gn);color:#fff;width:20px;height:20px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:900;z-index:5}
.tc .fv{position:absolute;top:6px;right:6px;width:22px;height:22px;border-radius:50%;background:rgba(0,0,0,.5);border:none;color:#fff;font-size:10px;cursor:pointer;display:flex;align-items:center;justify-content:center;z-index:5;transition:all .2s}
.tc .fv:hover{background:var(--pk);transform:scale(1.1)}.tc .fv.on{background:var(--pk)}
.tp{height:140px;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:10px;overflow:hidden}
.ti{padding:8px 10px;border-top:1px solid var(--bd);display:flex;justify-content:space-between;align-items:center}
.tn{font-weight:700;font-size:.7em}.te{font-size:.52em;color:var(--tx2);direction:ltr;display:block;margin-top:1px}
.tt{font-size:.48em;padding:2px 6px;border-radius:4px;background:var(--s2);color:var(--tx2)}

/* ===== PREVIEW ===== */
.box{max-width:400px;margin:0 auto;border-radius:14px;overflow:hidden;box-shadow:0 8px 30px rgba(0,0,0,.5);border:1px solid var(--bd);transition:max-width .3s}
.scr{display:flex;justify-content:center;gap:6px;margin:12px 0}
.scr button{border:2px solid var(--bd);border-radius:8px;cursor:pointer;transition:all .2s;padding:0;background:none}
.scr button:hover{border-color:var(--ac)}.scr button.on{border-color:var(--gn)}
.scr span{font-size:.64em;font-weight:600;padding:4px 10px;background:var(--s2);text-align:center;display:block;border-radius:5px}
.fw{perspective:1000px;width:100%;max-width:400px;margin:16px auto;cursor:pointer}
.fi{position:relative;width:100%;transition:transform .6s cubic-bezier(.4,0,.2,1);transform-style:preserve-3d}
.fi.flipped{transform:rotateY(180deg)}
.ff,.fbk{backface-visibility:hidden;-webkit-backface-visibility:hidden;width:100%}
.fbk{position:absolute;top:0;left:0;transform:rotateY(180deg)}
.cmp{display:flex;gap:12px;justify-content:center;margin:14px 0;flex-wrap:wrap}
.cbx{flex:1;min-width:200px;max-width:400px;border:2px solid var(--bd);border-radius:var(--r);overflow:hidden;animation:fadeIn .3s ease}
.cbl{padding:5px;text-align:center;font-weight:700;font-size:.76em;background:var(--s2)}

/* ===== DOWNLOAD ===== */
.dla{text-align:center;padding:28px 16px;background:linear-gradient(135deg,rgba(99,102,241,.04),rgba(168,85,247,.04));border-radius:14px;border:1px solid var(--bd);margin:14px 0}
.dlb{display:flex;gap:6px;justify-content:center;flex-wrap:wrap;margin-top:14px}
.ld{display:none;text-align:center;padding:14px}.ld.on{display:block}
.spn{width:28px;height:28px;border:3px solid var(--bd);border-top-color:var(--ac);border-radius:50%;animation:spin .8s linear infinite;margin:0 auto 8px}
.spw{background:var(--s1);border:1px solid var(--bd);border-radius:8px;padding:10px;text-align:center;margin:10px 0}
.spt{font-size:.78em;font-weight:700;margin-bottom:6px}
.sps{display:flex;gap:4px;justify-content:center}
.spb{padding:5px 12px;border:2px solid var(--bd);border-radius:6px;background:var(--s2);color:var(--tx);cursor:pointer;transition:all .2s;font-size:.68em;font-weight:600;font-family:inherit}
.spb:hover{border-color:var(--ac)}.spb.on{border-color:var(--gn);background:rgba(34,197,94,.08);color:var(--gn)}
.sts{display:grid;grid-template-columns:repeat(5,1fr);gap:6px;margin:10px 0}
.sti{background:var(--s2);border:1px solid var(--bd);border-radius:6px;padding:8px 4px;text-align:center}
.stv{font-size:.92em;font-weight:800;color:var(--ac2)}.stl{font-size:.54em;color:var(--tx2);margin-top:2px}

/* ===== MODAL ===== */
.mb{position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:100;display:none;align-items:center;justify-content:center;backdrop-filter:blur(4px)}
.mb.show{display:flex}
.ml{background:var(--s1);border:1px solid var(--bd);border-radius:14px;padding:20px;max-width:440px;width:90%;max-height:80vh;overflow-y:auto;box-shadow:0 8px 40px rgba(0,0,0,.5);animation:fadeIn .3s ease}
.ml h3{margin-bottom:10px;font-size:.95em}
.mx{float:left;cursor:pointer;font-size:1.2em;color:var(--tx2);transition:color .2s}.mx:hover{color:var(--tx)}
.toast{position:fixed;bottom:16px;left:50%;transform:translateX(-50%);z-index:999;background:var(--gn);color:#fff;padding:6px 14px;border-radius:8px;font-weight:700;font-size:.74em;box-shadow:0 4px 12px rgba(34,197,94,.3);opacity:0;transition:all .3s;pointer-events:none}
.toast.show{opacity:1;transform:translateX(-50%) translateY(-4px)}
.tc2{display:none}.tc2.on{display:block;animation:fadeIn .3s ease}
.emp{text-align:center;padding:40px 16px;color:var(--tx2)}.emp span{font-size:2.2em;display:block;margin-bottom:8px;opacity:.5;animation:float 3s ease-in-out infinite}

/* ===== RESPONSIVE ===== */
@media(max-width:800px){.side{position:fixed;top:52px;right:0;bottom:0;width:300px;z-index:40;transform:translateX(100%);transition:transform .3s}.side.open{transform:translateX(0)}.sb-tog{display:block}.gg{grid-template-columns:1fr 1fr}.sts{grid-template-columns:repeat(3,1fr)}.top-actions .abtn:not(.ac):not(.sm){display:none}}
@media(max-width:500px){.gg{grid-template-columns:1fr}.tabs{gap:1px}.tab{padding:4px 8px;font-size:.64em}.sts{grid-template-columns:1fr 1fr}.top-actions{gap:4px}}
</style>
</head>
<body>
<div class="topbar">
  <button class="sb-tog" onclick="togSide()">☰</button>
  <div class="logo"><i>🎨</i><b>Anki Studio</b></div>
  <div class="tabs">
    <button class="tab on" data-t="gal" onclick="go('gal')">🎨 المعرض</button>
    <button class="tab" data-t="pv" onclick="go('pv')">👁️ معاينة</button>
    <button class="tab" data-t="dl" onclick="go('dl')">📦 تحميل</button>
  </div>
  <div class="top-actions">
    <button class="abtn sm" onclick="undo()" id="ub" disabled title="تراجع">↩️</button>
    <button class="abtn sm" onclick="redo()" id="rb" disabled title="إعادة">↪️</button>
    <button class="abtn sm" onclick="rnd()" title="تصميم عشوائي">🎲</button>
    <button class="abtn sm" onclick="share()" title="مشاركة">🔗</button>
    <button class="abtn ac" onclick="dl(false)">⬇️ تحميل</button>
  </div>
</div>
<div class="app">
  <div class="side" id="side"></div>
  <div class="main">
    <div class="tc2 on" id="t-gal">
      <div class="gh">
        <div class="gs">🔍 <input type="text" id="gsrch" placeholder="ابحث عن قالب..." oninput="rGal()"></div>
        <div class="gf" id="gfil"></div>
        <div class="gc" id="gct"></div>
      </div>
      <div class="gg" id="ggrid"></div>
    </div>
    <div class="tc2" id="t-pv">
      <div style="text-align:center;margin-bottom:12px"><div style="font-size:1.1em;font-weight:800;margin-bottom:3px">👁️ معاينة مباشرة</div><div style="font-size:.74em;color:var(--tx2)">اضغط البطاقة لقلبهاetween الوجهين</div></div>
      <div class="scr"><button class="on" onclick="scr2('mob',this)"><span>📱 جوال</span></button><button onclick="scr2('tab',this)"><span>📱 تابلت</span></button><button onclick="scr2('desk',this)"><span>💻 كمبيوتر</span></button></div>
      <div class="fw" onclick="flip()"><div class="fi" id="fip"><div class="ff"><div class="box" id="pvF"></div></div><div class="fbk"><div class="box" id="pvB"></div></div></div></div>
      <div style="text-align:center;margin-top:10px;display:flex;gap:6px;justify-content:center;flex-wrap:wrap"><button class="abtn" onclick="cmp()">📊 مقارنة</button><button class="abtn" onclick="go('gal')">🎨 تغيير القالب</button><button class="abtn ac" onclick="dl(false)">⬇️ حمّل الآن</button></div>
      <div id="cmpA" style="display:none"></div>
    </div>
    <div class="tc2" id="t-dl">
      <div style="text-align:center;margin-bottom:14px"><div style="font-size:1.1em;font-weight:800;margin-bottom:3px">📦 حمّل رزمة Anki</div><div style="font-size:.74em;color:var(--tx2)">الكلمات بالتصميم اللي صممته</div></div>
      <div class="sts" id="dsts"></div>
      <div class="spw"><div class="spt">🔀 تقسيم البطاقات</div><div class="sps"><button class="spb on" onclick="setSp('unified',this)">📘 موحدة</button><button class="spb" onclick="setSp('separate',this)">🔀 منفصلة</button></div></div>
      <div class="dla">
        <div style="font-size:2.2em;margin-bottom:6px;animation:float 3s ease-in-out infinite">📦</div>
        <div style="font-size:.82em;font-weight:700;margin-bottom:4px">جاهز للتحميل!</div>
        <div style="font-size:.68em;color:var(--tx2)">اضغط الزر المناسب لتحميل رزتك</div>
        <div class="dlb">
          <button class="abtn ac" onclick="dl(false)">⬇️ تحميل واحد</button>
          <button class="abtn" onclick="dl(true)">🌓 نسختين (فاتح + داكن)</button>
          <button class="abtn" onclick="expCSS()">📋 نسخ CSS</button>
          <button class="abtn" onclick="expJSON()">💾 تصدير JSON</button>
          <button class="abtn" onclick="share()">🔗 مشاركة</button>
        </div>
        <div class="ld" id="dld"><div class="spn"></div><p style="color:var(--ac2);font-weight:600;font-size:.78em">جاري التوليد...</p></div>
        <div id="dli" style="color:var(--tx2);margin-top:10px;font-size:.74em"></div>
      </div>
    </div>
  </div>
</div>
<div class="mb" id="mShare"><div class="ml"><span class="mx" onclick="cm('mShare')">&times;</span><h3>🔗 مشاركة التصميم</h3><p style="font-size:.72em;color:var(--tx2);margin-bottom:8px">انسخ الرابط وأرسله لأي شخص ليفتح التصميم ذاته</p><input type="text" class="hx" id="surl" readonly style="width:100%;direction:ltr;text-align:left;padding:8px;margin:8px 0"><div style="text-align:center"><button class="abtn" onclick="cps()">📋 نسخ الرابط</button></div></div></div>
<div class="mb" id="mSave"><div class="ml"><span class="mx" onclick="cm('mSave')">&times;</span><h3>💾 حفظ التصميم</h3><p style="font-size:.72em;color:var(--tx2);margin-bottom:8px">أعط التصميم اسم لتحميله لاحقاً</p><input type="text" class="tx" id="tname" placeholder="اسم التصميم..." style="width:100%;padding:8px;margin:8px 0"><div style="text-align:center"><button class="abtn gn" onclick="cfs()">💾 حفظ</button></div></div></div>
<div class="mb" id="mJson"><div class="ml"><span class="mx" onclick="cm('mJson')">&times;</span><h3>📋 استيراد إعدادات JSON</h3><p style="font-size:.72em;color:var(--tx2);margin-bottom:8px">الصق إعدادات التصميم هنا لتطبيقها</p><textarea class="tx" id="jinp" style="width:100%;min-height:100px;padding:8px;margin:8px 0;direction:ltr;font-family:'Fira Code',monospace" placeholder='{"cardBg":"#ffffff",...}'></textarea><div style="text-align:center"><button class="abtn ac" onclick="cfj()">📥 استيراد وتطبيق</button></div></div></div>
<div class="toast" id="toast"></div>
<div class="toast" id="toast"></div>
<script>

SB.forEach(function(s){if(s.fd)s.fd.forEach(function(f){if(f.id)S[f.id]=f.d;});});
S.sectionOrder=SC.slice();S.sectionVisibility={};SC.forEach(function(s){S.sectionVisibility[s]=true;});
S.showBadge=true;S.showUnitBadge=true;S.showMeaning=true;S.showPage=true;S.sel=0;S.cat='all';S.effect='none';S.sp='unived';
function ph(){HP.push(JSON.stringify(S));if(HP.length>50)HP.shift();HF=[];uu();}
function uu(){var u=document.getElementById('ub'),r=document.getElementById('rb');if(u)u.disabled=!HP.length;if(r)r.disabled=!HF.length;}
function toast(m){var t=document.getElementById('toast');t.textContent=m;t.className='toast show';clearTimeout(t._t);t._t=setTimeout(function(){t.className='toast';},2200);}
function cl(v){return{min:'نظيف',dark:'داكن',grad:'متدرج',viv:'حيوي',nat:'طبيعي',eleg:'أنيق',bold:'جريء'}[v]||v;}
function rSide(){var sb=document.getElementById('side'),h='';SB.forEach(function(s){h+='<div class="ss"><div class="sh open" onclick="ts(this)"><span>'+s.ic+' '+s.tt+'</span><span class="sa">▼</span></div><div class="sb open">';if(s.tp==='qa'){h+='<div class="sc"><div class="sl">⚡ ستايلات جاهزة</div><div class="qag">';QA.forEach(function(q,i){h+='<button class="qab" onclick="aq('+i+')" style="background:linear-gradient(135deg,'+q.bg+','+(q.bg2||q.bg)+');color:'+q.fc+'">'+q.nm+'</button>';});h+='</div><button class="abtn" style="width:100%;margin-top:4px;text-align:center" onclick="rd()">🔄 إعادة تعيين</button></div>';}
else if(s.tp==='vis'){h+='<div class="sc"><div class="sl">الأقسام</div>';SC.forEach(function(k){h+='<div class="tg '+(S.sectionVisibility[k]!==false?'on':'')+'" onclick="tsSec(\''+k+'\')"><div class="td">✓</div><span class="tl">'+SE[k]+' '+SL[k]+'</span></div>';});h+='</div><div class="sc"><div class="sl">العناصر</div>';[{k:'showBadge',l:'🏷️ Badges'},{k:'showUnitBadge',l:'📘 Unit'},{k:'showMeaning',l:'🇸🇦 المعنى'},{k:'showPage',l:'📄 الصفحة'}].forEach(function(x){h+='<div class="tg '+(S[x.k]?'on':'')+'" onclick="tsBool(\''+x.k+'\')"><div class="td">✓</div><span class="tl">'+x.l+'</span></div>';});h+='</div>';}
else if(s.tp==='srt'){h+='<div class="sc"><div class="sl">اربط بالترتيب</div>';S.sectionOrder.forEach(function(k,i){h+='<div class="srt" draggable="true" ondragstart="dS(event,'+i+')" ondragover="event.preventDefault()" ondrop="dD(event,'+i+')"><span style="color:var(--tx3)">⋮⋮</span><span class="srn">'+(i+1)+'</span><span>'+SE[k]+' '+SL[k]+'</span></div>';});h+='</div>';}
else if(s.tp==='tpl'){var sv=JSON.parse(localStorage.getItem('anki_tpls')||'{}'),ns=Object.keys(sv);h+='<div class="sc"><div class="sl">القوالب</div>';if(ns.length){ns.forEach(function(n){h+='<div style="display:flex;gap:3px;align-items:center;padding:3px 6px;background:var(--s3);border-radius:3px;font-size:.62em;margin-bottom:2px"><span style="flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">'+n+'</span><button class="abtn" style="padding:1px 4px;font-size:.52em" onclick="lT(\''+n.replace(/'/g,"\\'")+'\')">📂</button><button class="abtn rd" style="padding:1px 4px;font-size:.52em" onclick="dT(\''+n.replace(/'/g,"\\'")+'\')">🗑️</button></div>';});}else h+='<div style="font-size:.62em;color:var(--tx3);text-align:center;padding:4px">لا توجد</div>';h+='<button class="abtn gn" style="width:100%;margin-top:4px;text-align:center" onclick="oS()">💾 حفظ الحالي</button></div>';}
else if(s.tp==='pal'){h+='<div class="sc"><div class="sl">🎨 أدخل لون</div><div class="sr"><input type="color" class="clr" id="palIn" value="#6366f1" oninput="gPal(this.value)"><button class="abtn" onclick="gPal(document.getElementById(\'palIn\').value)">generate</button></div><div id="palOut" style="margin-top:4px"></div></div>';}
else if(s.fd){s.fd.forEach(function(f){if(f.t==='fx'){h+='<div class="sc"><div class="sl">'+f.lb+'</div><div class="fxg">';FX.forEach(function(x){h+='<button class="fxb '+(S[f.id]===x.i?'on':'')+'" onclick="setFx(\''+x.i+'\')">'+x.e+' '+x.n+'</button>';});h+='</div></div>';}else if(f.t==='c'){h+='<div class="sc"><div class="sl">'+f.lb+'</div><div class="sr"><input type="color" class="clr" value="'+(S[f.id]||'#ffffff')+'" oninput="setC(\''+f.id+'\',this.value)"><input type="text" class="hx" value="'+(S[f.id]||'')+'" onchange="setC(\''+f.id+'\',this.value)"></div></div>';}else if(f.t==='r'){var v=S[f.id]!==undefined?S[f.id]:f.d;h+='<div class="sc"><div class="sl">'+f.lb+'</div><div class="sr"><div class="rg"><input type="range" min="'+f.mn+'" max="'+f.mx+'" step="'+f.st+'" value="'+v+'" oninput="setR(\''+f.id+'\',this.value,\''+f.u+'\')"><span class="rv" id="rv_'+f.id+'">'+v+f.u+'</span></div></div></div>';}else if(f.t==='s'){h+='<div class="sc"><div class="sl">'+f.lb+'</div><select class="sl2" onchange="setS(\''+f.id+'\',this.value)">';f.o.forEach(function(o){h+='<option value="'+o+'" '+(S[f.id]===o?'selected':'')+'>'+o+'</option>';});h+='</select></div>';if(f.fp){h+='<div class="fp"><div class="s" style="font-family:'+(S[f.id]||f.d)+'">The quick brown fox</div><div class="n">'+(S[f.id]||f.d).split(",")[0].replace(/'/g,'')+'</div></div>';}}else if(f.t==='x')h+='<div class="sc"><div class="sl">'+f.lb+'</div><input type="text" class="tx" value="'+(S[f.id]||'')+'" placeholder="0 2px 8px rgba(0,0,0,.3)" onchange="setT(\''+f.id+'\',this.value)"></div>';else if(f.t==='txt')h+='<div class="sc"><div class="sl">'+f.lb+'</div><input type="text" class="tx" value="'+(S[f.id]||f.d||'')+'" onchange="setT(\''+f.id+'\',this.value)"></div>';});}h+='</div></div>';});sb.innerHTML=h;}
function ts(el){el.classList.toggle('open');el.nextElementSibling.classList.toggle('open');}
function rGal(){var g=document.getElementById('ggrid'),q=(document.getElementById('gsrch').value||'').toLowerCase();var f=T.filter(function(t){if(S.cat!=='all'&&t.c!==S.cat)return false;if(q&&t.n.indexOf(q)===-1&&t.en.toLowerCase().indexOf(q)===-1)return false;return true;});document.getElementById('gct').textContent=f.length+'/'+T.length;if(!f.length){g.innerHTML='<div class="emp"><span>🔍</span><div>لا توجد نتائج</div></div>';return;}g.innerHTML=f.map(function(t,vi){var ri=T.indexOf(t),sel=ri===S.sel?'sel':'',bg=t.bg2?'linear-gradient(135deg,'+t.bg+','+t.bg2+')':t.bg,fv=FAV.indexOf(ri)!==-1;return '<div class="tc '+sel+'" style="animation-delay:'+Math.min(vi*30,400)+'ms" onclick="sT('+ri+')"><button class="fv '+(fv?'on':'')+'" onclick="event.stopPropagation();tFv('+ri+')">'+(fv?'❤️':'🤍')+'</button><div class="tp" style="background:'+bg+'"><div style="font-family:Inter;font-size:.9em;font-weight:900;color:'+t.fc+';direction:ltr;margin-bottom:4px">'+SA.f+'</div><div style="background:'+t.mb+';border:1px solid '+t.mbd+';border-radius:6px;padding:2px 8px;color:'+t.mc+';font-size:.65em;font-family:\'Noto Sans Arabic\'">'+SA.a+'</div><div style="margin-top:3px"><span style="background:'+t.bnbg+';color:'+t.bnc+';padding:1px 4px;border-radius:4px;font-size:.42em;font-weight:700">N.</span> <span style="background:'+t.ubg+';color:'+t.uc+';padding:1px 4px;border-radius:4px;font-size:.42em;font-weight:700;border:1px solid '+t.ubd+'">Unit 1</span></div></div><div class="ti"><div><span class="tn">'+t.n+'</span><span class="te">'+t.en+'</span></div><span class="tt">'+cl(t.c)+'</span></div></div>';}).join('');}
function gFil(){var m={all:'الكل',min:'نظيف',dark:'داكن',grad:'متدرج',viv:'حيوي',nat:'طبيعي',eleg:'أنيق',bold:'جريء'};document.getElementById('gfil').innerHTML=Object.entries(m).map(function(kv){return '<button class="gb '+(kv[0]===S.cat?'on':'')+'" onclick="setCt(\''+kv[0]+'\')">'+kv[1]+'</button>';}).join('');}
function setCt(c){S.cat=c;gFil();rGal();}
function sT(i){ph();S.sel=i;var t=T[i];S.cardBg=t.bg;S.cardBg2=t.bg2||'';S.frenchColor=t.fc;S.meaningBg=t.mb;S.meaningBorder=t.mbd;S.meaningColor=t.mc;S.textColor=t.tc;S.badgeNomBg=t.bnbg;S.badgeNomColor=t.bnc;S.badgeAdjBg=t.babg;S.badgeAdjColor=t.bac;S.badgeVerbBg=t.bvbg;S.badgeVerbColor=t.bvc;S.unitBg=t.ubg;S.unitColor=t.uc;S.unitBorder=t.ubd;S.secBg=t.sb;S.secBorder=t.sbd;S.secTextColor=t.sc;S.labelColor=t.lc;if(t.fx)S.effect=t.fx;rGal();rSide();uP();toast('✅ '+t.n);}
function tFv(i){var x=FAV.indexOf(i);if(x===-1){FAV.push(i);toast('❤️');}else{FAV.splice(x,1);toast('💔');}localStorage.setItem('anki_favs',JSON.stringify(FAV));rGal();}
function setC(id,v){ph();S[id]=v;uP();rSide();}
function setR(id,v,u){S[id]=parseFloat(v);var rv=document.getElementById('rv_'+id);if(rv)rv.textContent=v+u;uP();}

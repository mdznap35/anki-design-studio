function cfs(){var n=document.getElementById('tname').value.trim();if(!n){toast('❌ أدخل اسمًا');return;}var sv=JSON.parse(localStorage.getItem('anki_tpls')||'{}');sv[n]={c:bC(),s:S.sel};localStorage.setItem('anki_tpls',JSON.stringify(sv));cm('mSave');rSide();toast('💾 '+n);}
function lT(n){var sv=JSON.parse(localStorage.getItem('anki_tpls')||'{}');if(!sv[n])return;ph();var c=sv[n].c;Object.keys(c).forEach(function(k){if(k in S)S[k]=c[k];});if(c.sectionOrder)S.sectionOrder=c.sectionOrder.split(',');if(c.sectionVisibility)S.sectionVisibility=c.sectionVisibility;if(c.effect)S.effect=c.effect;if(c.splitDirection)S.sp=c.splitDirection;if(sv[n].s!==undefined)S.sel=sv[n].s;rGal();rSide();uP();toast('📂 '+n);}
function dT(n){if(!confirm('حذف "'+n+'"؟'))return;var sv=JSON.parse(localStorage.getItem('anki_tpls')||'{}');delete sv[n];localStorage.setItem('anki_tpls',JSON.stringify(sv));rSide();toast('🗑️');}
function rnd(){ph();var i=Math.floor(Math.random()*T.length);sT(i);S.frenchFontSize=+(1.5+Math.random()*3).toFixed(1);S.meaningFontSize=+(0.8+Math.random()*2).toFixed(1);S.borderRadius=Math.floor(Math.random()*50);S.cardPadding=Math.floor(8+Math.random()*52);S.cardGap=Math.floor(Math.random()*30);var fx=['none','neon','wave','sakura','ember','float','glow','bounce','pulse_border','gradient'];S.effect=fx[Math.floor(Math.random()*fx.length)];rSide();uP();toast('🎲 عشوائي!');}
function bC(){var c={};SB.forEach(function(s){if(s.fd)s.fd.forEach(function(f){if(f.id&&f.t!=='fx')c[f.id]=S[f.id];});});c.effect=S.effect;c.sectionOrder=S.sectionOrder.join(',');c.sectionVisibility=S.sectionVisibility;c.showBadge=S.showBadge;c.showUnitBadge=S.showUnitBadge;c.showMeaning=S.showMeaning;c.showPage=S.showPage;c.splitDirection=S.sp;return c;}
function expCSS(){var c=bC(),bg=c.cardBg2?'linear-gradient('+(c.bgGradientDir||'135deg')+','+c.cardBg+','+c.cardBg2+')':c.cardBg;var css='.card{background:'+bg+';color:'+(c.textColor||'#333')+';border-radius:'+(c.borderRadius||16)+'px;padding:'+(c.cardPadding||28)+'px}\n.french{font-size:'+(c.frenchFontSize||2.4)+'em;color:'+(c.frenchColor||'#1e293b')+'}\n.meaning{background:'+(c.meaningBg||'#eff6ff')+';border-radius:'+(c.meaningBorderRadius||16)+'px;color:'+(c.meaningColor||'#1e40af')+'}\n';navigator.clipboard.writeText(css).then(function(){toast('📋 نسخ!');}).catch(function(){toast('❌');});}
function expJSON(){var c=bC();var b=new Blob([JSON.stringify(c,null,2)],{type:'application/json'});var u=URL.createObjectURL(b);var a=document.createElement('a');a.href=u;a.download='anki-design.json';a.click();URL.revokeObjectURL(u);toast('💾 تم!');}
function cfj(){try{var c=JSON.parse(document.getElementById('jinp').value);ph();Object.keys(c).forEach(function(k){if(k in S)S[k]=c[k];});if(c.sectionOrder)S.sectionOrder=c.sectionOrder.split(',');if(c.sectionVisibility)S.sectionVisibility=c.sectionVisibility;if(c.effect)S.effect=c.effect;cm('mJson');rGal();rSide();uP();toast('📥 تم!');}catch(e){toast('❌ JSON غير صالح');}}

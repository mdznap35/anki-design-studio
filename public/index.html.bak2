function tsBool(k){ph();S[k]=!S[k];rSide();uP();}
var dI=null;
function dS(e,i){dI=i;e.target.classList.add('dragging');e.dataTransfer.effectAllowed='move';}
function dD(e,i){e.preventDefault();if(dI===null||dI===i)return;ph();var it=S.sectionOrder.splice(dI,1)[0];S.sectionOrder.splice(i,0,it);dI=null;rSide();uP();}
function aq(i){ph();var q=QA[i];Object.keys(q).forEach(function(k){if(k!=='nm'&&k in S)S[k]=q[k];});rSide();uP();toast('⚡ '+q.nm);}
function rd(){ph();SB.forEach(function(s){if(s.fd)s.fd.forEach(function(f){if(f.id)S[f.id]=f.d;});});S.sectionOrder=SC.slice();SC.forEach(function(k){S.sectionVisibility[k]=true;});S.showBadge=true;S.showUnitBadge=true;S.showMeaning=true;S.showPage=true;S.effect='none';S.sp='unived';rSide();uP();toast('🔄 إعادة تعيين');}
function gPal(hex){var r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16);var l='rgb('+Math.min(255,r+100)+','+Math.min(255,g+100)+','+Math.min(255,b+100)+')',d='rgb('+Math.max(0,r-80)+','+Math.max(0,g-80)+','+Math.max(0,b-80)+')',c='rgb('+(255-r)+','+(255-g)+','+(255-b)+')';document.getElementById('palOut').innerHTML='<div style="display:flex;gap:3px;flex-wrap:wrap"><div style="width:100%;padding:3px 6px;background:'+hex+';color:#fff;border-radius:3px;font-size:.58em;text-align:center;font-weight:600">أساسي: '+hex+'</div><div style="flex:1;min-width:45px;padding:3px;background:'+l+';color:#333;border-radius:3px;font-size:.52em;text-align:center">فاتح</div><div style="flex:1;min-width:45px;padding:3px;background:'+d+';color:#fff;border-radius:3px;font-size:.52em;text-align:center">غامق</div><div style="flex:1;min-width:45px;padding:3px;background:'+c+';color:#fff;border-radius:3px;font-size:.52em;text-align:center">مكمل</div></div>';}
function mkCard(){var bg=S.cardBg2?'linear-gradient('+(S.bgGradientDir||'135deg')+','+S.cardBg+','+S.cardBg2+')':S.cardBg;var c='background:'+bg+';border-radius:'+(S.borderRadius||16)+'px;padding:'+(S.cardPadding||28)+'px 20px;min-height:'+(S.cardMinHeight||300)+'px;display:flex;flex-direction:'+(S.cardDirection||'column')+';align-items:'+(S.cardAlign||'center')+';justify-content:center;color:'+(S.textColor||'#333')+';gap:'+(S.cardGap||10)+'px;font-family:'+(S.fontArabic||"'Noto Sans Arabic'")+';width:100%;box-sizing:border-box;';if(S.cardBorderWidth)c+='border:'+S.cardBorderWidth+'px solid '+(S.cardBorderColor||'#e2e8f0')+';';if(S.cardShadow&&S.cardShadow!=='none')c+='box-shadow:'+S.cardShadow+';';var h='<div style="'+c+'">';h+='<div style="font-family:'+(S.fontFrench||"'Inter'")+';font-size:'+(S.frenchFontSize||2.4)+'em;font-weight:'+(S.frenchFontWeight||900)+';direction:ltr;color:'+(S.frenchColor||'#1e293b')+';'+(S.frenchTextShadow?'text-shadow:'+S.frenchTextShadow+';':'')+'">'+SA.f+'</div>';if(S.showBadge)h+='<div style="margin:4px 0"><span style="background:'+(S.badgeNomBg||'#dbeafe')+';color:'+(S.badgeNomColor||'#1e40af')+';padding:3px 12px;border-radius:16px;font-size:.68em;font-weight:700;display:inline-block;margin:2px;'+(S.badgeShadow?'box-shadow:'+S.badgeShadow+';':'')+'">'+SA.tp+'</span></div>';if(S.showUnitBadge)h+='<div style="margin:4px 0"><span style="background:'+(S.unitBg||'#f0fdf4')+';color:'+(S.unitColor||'#166534')+';border:1px solid '+(S.unitBorder||'#bbf7d0')+';padding:2px 10px;border-radius:16px;font-size:.64em;font-weight:700;display:inline-block;margin:2px">Unit '+SA.u+'</span></div>';h+='<hr style="border:none;border-top:1px '+(S.separatorStyle||'dashed')+' '+(S.separatorColor||'#e2e8f0')+';margin:4px 20px;width:100%">';if(S.showMeaning)h+='<div style="background:'+(S.meaningBg||'#eff6ff')+';border:'+(S.meaningBorderWidth||2)+'px solid '+(S.meaningBorder||'#bfdbfe')+';border-radius:'+(S.meaningBorderRadius||16)+'px;padding:10px 18px;color:'+(S.meaningColor||'#1e40af')+';font-size:'+(S.meaningFontSize||1.5)+'em;font-weight:'+(S.meaningFontWeight||800)+';max-width:90%">'+SA.a+'</div>';var sd={pluriel:{l:'Pluriel',v:SA.p},masculin:{l:'Masc.',v:'Un abonnement / Des abonnements'},feminin:{l:'Fem.',v:'Une abonnée / Des abonnées'},preposition:{l:'Prep.',v:'abonner à'},auxiliaire:{l:'Aux.',v:'avoir'},participe:{l:'Part.',v:'abonné'},synonyme:{l:'Syn.',v:'adhésion'},contraire:{l:'Contr.',v:'désabonnement'}};S.sectionOrder.forEach(function(k){if(S.sectionVisibility[k]===false)return;var s=sd[k];if(!s)return;h+='<div style="background:'+(S.secBg||'#f8f9fa')+';border:1px solid '+(S.secBorder||'#e2e8f0')+';border-radius:10px;padding:8px 14px;margin:3px 0;width:100%;max-width:460px;text-align:center"><div style="font-size:.55em;color:'+(S.labelColor||'#999')+';text-transform:uppercase;letter-spacing:1.5px;margin-bottom:2px">'+s.l+'</div><div style="font-size:.82em;font-weight:700;direction:ltr;color:'+(S.secTextColor||'#333')+'">'+s.v+'</div></div>';});if(S.showPage)h+='<div style="font-size:.55em;color:'+(S.labelColor||'#999')+';margin-top:3px">Page 12</div>';h+='</div>';return h;}
